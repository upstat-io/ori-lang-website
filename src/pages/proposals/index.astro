---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProposals = await getCollection('proposals');

// Group by status
const approved = allProposals
  .filter(p => p.data.status === 'approved')
  .sort((a, b) => {
    if (a.data.approved && b.data.approved) return b.data.approved.localeCompare(a.data.approved);
    return a.data.title.localeCompare(b.data.title);
  });

const drafts = allProposals
  .filter(p => p.data.status === 'draft')
  .sort((a, b) => {
    if (a.data.created && b.data.created) return b.data.created.localeCompare(a.data.created);
    return a.data.title.localeCompare(b.data.title);
  });

const rejected = allProposals
  .filter(p => p.data.status === 'rejected')
  .sort((a, b) => {
    if (a.data.rejected && b.data.rejected) return b.data.rejected.localeCompare(a.data.rejected);
    return a.data.title.localeCompare(b.data.title);
  });

function formatDate(dateStr: string | undefined): string | undefined {
  if (!dateStr) return undefined;
  const match = dateStr.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!match) return dateStr;
  const [, year, month, day] = match;
  const months = ['January', 'February', 'March', 'April', 'May', 'June',
                  'July', 'August', 'September', 'October', 'November', 'December'];
  const monthName = months[parseInt(month, 10) - 1];
  return `${monthName} ${parseInt(day, 10)}, ${year}`;
}
---

<BaseLayout
  title="Language Proposals — Ori"
  description={`Ori language proposals: ${approved.length} approved, ${drafts.length} drafts, ${rejected.length} rejected. Design decisions and rationale for language features.`}
  keywords="Ori proposals, language design, RFC, feature proposals"
>
  <main class="proposals-page">
    <section class="proposals-hero">
      <h1 class="gradient-title">Language Proposals</h1>
      <p class="proposals-subtitle">
        Design decisions and rationale for language features. Proposals go through draft review before approval or rejection.
      </p>
      <div class="proposal-stats">
        <span class="proposal-stat approved">{approved.length} approved</span>
        <span class="proposal-stat draft">{drafts.length} drafts</span>
        <span class="proposal-stat rejected">{rejected.length} rejected</span>
      </div>
      <a href="/roadmap/" class="back-to-roadmap"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12" fill="currentColor" style="vertical-align: -0.125em" aria-hidden="true"><path d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 288 480 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-370.7 0 105.4-105.4c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/></svg> Back to Roadmap</a>
    </section>

    <section class="status-section draft-proposals-section">
      <details open>
        <summary class="status-header draft-header">
          <span class="status-icon">&cir;</span>
          <h2>Drafts</h2>
          <span class="status-count">{drafts.length} proposals</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="proposal-grid">
          {drafts.map((proposal) => (
            <a
              href={`/proposals/${proposal.id}/`}
              class="proposal-card draft"
            >
              <h3>{proposal.data.title}</h3>
              {proposal.data.summary && <p class="proposal-summary">{proposal.data.summary}</p>}
              <div class="proposal-meta">
                {proposal.data.author && <span class="proposal-author">{proposal.data.author}</span>}
                {proposal.data.created && <span class="proposal-date">Created {formatDate(proposal.data.created)}</span>}
              </div>
            </a>
          ))}
        </div>
      </details>
    </section>

    <section class="status-section approved-proposals-section">
      <details open>
        <summary class="status-header approved-header">
          <span class="status-icon">&check;</span>
          <h2>Approved</h2>
          <span class="status-count">{approved.length} proposals</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="proposal-grid">
          {approved.map((proposal) => (
            <a
              href={`/proposals/${proposal.id}/`}
              class="proposal-card approved"
            >
              <h3>{proposal.data.title}</h3>
              {proposal.data.summary && <p class="proposal-summary">{proposal.data.summary}</p>}
              <div class="proposal-meta">
                {proposal.data.author && <span class="proposal-author">{proposal.data.author}</span>}
                {proposal.data.approved && <span class="proposal-date">Approved {formatDate(proposal.data.approved)}</span>}
              </div>
            </a>
          ))}
        </div>
      </details>
    </section>

    <section class="status-section rejected-proposals-section">
      <details>
        <summary class="status-header rejected-header">
          <span class="status-icon">&times;</span>
          <h2>Rejected</h2>
          <span class="status-count">{rejected.length} proposals</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="proposal-grid">
          {rejected.map((proposal) => (
            <a
              href={`/proposals/${proposal.id}/`}
              class="proposal-card rejected"
            >
              <h3>{proposal.data.title}</h3>
              {proposal.data.summary && <p class="proposal-summary">{proposal.data.summary}</p>}
              <div class="proposal-meta">
                {proposal.data.author && <span class="proposal-author">{proposal.data.author}</span>}
                {proposal.data.rejected && <span class="proposal-date">Rejected {formatDate(proposal.data.rejected)}</span>}
              </div>
            </a>
          ))}
        </div>
      </details>
    </section>
  </main>
</BaseLayout>

<style>
  .proposals-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .proposals-hero {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .proposals-hero h1 {
    font-size: var(--text-5xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .proposals-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .proposal-stats {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .proposal-stat {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .proposal-stat.approved {
    background: rgba(126, 183, 166, 0.15);
    color: var(--color-success);
  }

  .proposal-stat.draft {
    background: rgba(219, 132, 75, 0.15);
    color: var(--color-warning);
  }

  .proposal-stat.rejected {
    background: rgba(232, 64, 64, 0.15);
    color: var(--color-error, #e84040);
  }

  .back-to-roadmap {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-to-roadmap:hover {
    color: var(--color-accent);
  }

  /* Status sections — same pattern as roadmap */
  .status-section {
    margin-bottom: var(--space-4);
  }

  .status-section details {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .status-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    list-style: none;
  }

  .status-header::-webkit-details-marker {
    display: none;
  }

  .status-header h2 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 0;
    flex: 1;
  }

  .status-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }

  .status-count {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .expand-icon {
    width: 20px;
    height: 20px;
    position: relative;
    color: var(--color-text-muted);
  }

  .expand-icon::before {
    content: "\25B8";
    font-size: var(--text-sm);
    transition: transform 0.2s ease;
    display: inline-block;
  }

  details[open] .expand-icon::before {
    transform: rotate(90deg);
  }

  /* Approved */
  .approved-proposals-section details {
    background: rgba(126, 183, 166, 0.02);
    border: 1px solid rgba(126, 183, 166, 0.15);
  }

  .approved-proposals-section details[open] {
    background: rgba(126, 183, 166, 0.03);
  }

  .status-header.approved-header h2 {
    color: var(--color-success);
  }

  .status-header.approved-header .status-icon {
    background: rgba(126, 183, 166, 0.15);
    color: var(--color-success);
  }

  /* Draft */
  .draft-proposals-section details {
    background: rgba(219, 132, 75, 0.02);
    border: 1px solid rgba(219, 132, 75, 0.15);
  }

  .draft-proposals-section details[open] {
    background: rgba(219, 132, 75, 0.03);
  }

  .status-header.draft-header h2 {
    color: var(--color-warning);
  }

  .status-header.draft-header .status-icon {
    background: rgba(219, 132, 75, 0.15);
    color: var(--color-warning);
  }

  /* Rejected */
  .rejected-proposals-section details {
    background: rgba(232, 64, 64, 0.02);
    border: 1px solid rgba(232, 64, 64, 0.15);
  }

  .rejected-proposals-section details[open] {
    background: rgba(232, 64, 64, 0.03);
  }

  .status-header.rejected-header h2 {
    color: var(--color-error, #e84040);
  }

  .status-header.rejected-header .status-icon {
    background: rgba(232, 64, 64, 0.15);
    color: var(--color-error, #e84040);
  }

  /* Proposal grid & cards */
  .proposal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
    padding: 0 var(--space-4) var(--space-4);
  }

  .proposal-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .proposal-card:hover {
    background: var(--color-bg-tertiary);
    border-color: var(--color-border-hover, var(--color-border));
    transform: translateY(-1px);
  }

  .proposal-card.approved {
    border-left: 3px solid var(--color-success);
  }

  .proposal-card.draft {
    border-left: 3px solid var(--color-warning);
  }

  .proposal-card.rejected {
    border-left: 3px solid var(--color-error, #e84040);
  }

  .proposal-card h3 {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2) 0;
    line-height: 1.3;
  }

  .proposal-summary {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3) 0;
    flex: 1;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .proposal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .proposals-hero h1 {
      font-size: var(--text-4xl);
    }

    .proposal-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
