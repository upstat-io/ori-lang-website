---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoadmapRow from '../../components/RoadmapRow.astro';
import { getCollection } from 'astro:content';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { join } from 'path';
import { publicPlans } from '../../lib/plan-data';
import TimelineMinimap from '../../components/TimelineMinimap.astro';

// Roadmap sections come from the v7 roadmap plan via the plan-sections collection.
interface RoadmapCard {
  num: number | string;
  slug: string;
  name: string;
  status: 'complete' | 'partial' | 'not-started';
  goal?: string;
  done: number;
  total: number;
}

const roadmapEntries = (await getCollection('plan-sections'))
  .filter(e => e.data.plan === 'roadmap')
  .sort((a, b) => Number(a.data.section) - Number(b.data.section));

const allSections: RoadmapCard[] = roadmapEntries.map(e => ({
  num: e.data.section,
  slug: e.id.slice(e.id.indexOf('/') + 1),
  name: e.data.title,
  status: e.data.status === 'complete' ? 'complete'
    : e.data.status === 'in-progress' ? 'partial'
    : 'not-started',
  goal: e.data.goal,
  done: e.data.done ?? 0,
  total: e.data.total ?? 0,
}));

const completedSections = allSections.filter(s => s.status === "complete");
const inProgressSections = allSections.filter(s => s.status === "partial");
const plannedSections = allSections.filter(s => s.status === "not-started");

const totalProgress = allSections.reduce(
  (acc, section) => ({ done: acc.done + section.done, total: acc.total + section.total }),
  { done: 0, total: 0 },
);
const overallPct = totalProgress.total > 0
  ? Math.round((totalProgress.done / totalProgress.total) * 100)
  : 0;

// Plan tracks grouped for the swimlane section
const activePlans = publicPlans.filter(p => p.status === 'active');
const queuedPlans = publicPlans.filter(p => p.status === 'queued');
const shippedPlans = publicPlans.filter(p => p.status === 'resolved');

// Load test results from CI
interface TestSuite {
  name: string;
  status?: string;        // "passed" | "failed" | "skipped" | "crashed" (for non-numeric suites like WASM)
  passed: number | null;
  failed: number | null;
  skipped: number | null;
  lcfail: number | null;  // LLVM compile failures
}

interface TestResults {
  timestamp?: string;
  overall?: string;
  suites: TestSuite[];
  totals: { passed: number; failed: number; skipped: number; lcfail: number };
}

function loadTestResults(): TestResults {
  const testResultsPath = join(process.cwd(), 'public', 'test-results.json');
  const empty: TestResults = { suites: [], totals: { passed: 0, failed: 0, skipped: 0, lcfail: 0 } };

  if (!existsSync(testResultsPath)) {
    return empty;
  }

  try {
    const content = readFileSync(testResultsPath, 'utf-8');
    const data = JSON.parse(content);

    // New format — has "suites" array
    if (data.suites && Array.isArray(data.suites)) {
      return {
        timestamp: data.timestamp,
        overall: data.overall,
        suites: data.suites,
        totals: data.totals ?? { passed: 0, failed: 0, skipped: 0, lcfail: 0 },
      };
    }

    // Legacy format — flat { rust_tests, ori_tests, llvm_tests }
    const suites: TestSuite[] = [
      { name: 'Rust Unit Tests', passed: data.rust_tests ?? 0, failed: data.rust_failed ?? 0, skipped: null, lcfail: null },
      { name: 'Ori Spec Tests', passed: data.ori_tests ?? 0, failed: data.ori_failed ?? 0, skipped: null, lcfail: null },
      { name: 'LLVM Backend Tests', passed: data.llvm_tests ?? 0, failed: data.llvm_failed ?? 0, skipped: null, lcfail: null },
    ];
    const totalPassed = suites.reduce((s, t) => s + (t.passed ?? 0), 0);
    const totalFailed = suites.reduce((s, t) => s + (t.failed ?? 0), 0);
    return {
      timestamp: data.timestamp,
      overall: totalFailed > 0 ? 'failed' : 'passed',
      suites,
      totals: { passed: totalPassed, failed: totalFailed, skipped: 0, lcfail: 0 },
    };
  } catch {
    return empty;
  }
}

const testResults = loadTestResults();

// Proposal counts (lightweight — just count files, don't parse)
function countProposals(dir: string): number {
  const proposalsDir = join(process.cwd(), '..', 'compiler_repo', 'docs', 'ori_lang', 'proposals', dir);
  if (!existsSync(proposalsDir)) return 0;
  return readdirSync(proposalsDir).filter(f => f.endsWith('.md')).length;
}

const approvedCount = countProposals('approved');
const draftCount = countProposals('drafts');
const rejectedCount = countProposals('rejected');
---

<BaseLayout
  title="Compiler Roadmap | OriLang"
  description={`OriLang compiler roadmap: ${allSections.length} sections. Track progress on type system, traits, capabilities, async, FFI, LLVM backend, and tooling.`}
  keywords="OriLang roadmap, compiler development, programming language, type system, async, FFI, LLVM, tooling, Ori compiler"
>
  <main class="roadmap-page">
    <section class="roadmap-hero">
      <h1 class="gradient-title">Compiler Roadmap</h1>
      <p class="roadmap-subtitle">
        Where the Ori compiler is today, what ships next, and what's already done.
      </p>
      <div class="hero-progress">
        <div class="hero-progress-meta">
          <span class="hero-progress-label">Overall progress</span>
          <span class="hero-progress-numbers">{totalProgress.done.toLocaleString()} / {totalProgress.total.toLocaleString()} work items</span>
        </div>
        <div class="hero-progress-bar">
          <div class="hero-progress-fill" style={`width: ${overallPct}%`}></div>
        </div>
        <span class="hero-progress-text">{overallPct}%</span>
      </div>
      <div class="stats">
        <div class="stat">
          <span class="stat-value warning">{inProgressSections.length}</span>
          <span class="stat-label">In Progress</span>
        </div>
        <div class="stat">
          <span class="stat-value muted">{plannedSections.length}</span>
          <span class="stat-label">Planned</span>
        </div>
        <div class="stat">
          <span class="stat-value success">{completedSections.length}</span>
          <span class="stat-label">Shipped</span>
        </div>
      </div>
    </section>

    <section class="timeline-section">
      <TimelineMinimap
        nodes={allSections.map(s => ({
          label: `Section ${s.num}`,
          name: s.name,
          status: s.status,
          scrollTarget: `section-${s.num}`,
        }))}
      />
    </section>

    <section class="lane lane-now">
      <header class="lane-header">
        <span class="lane-flag warning">Now</span>
        <h2>In Progress</h2>
        <span class="lane-count">{inProgressSections.length} sections</span>
      </header>
      <div class="lane-rows">
        {inProgressSections.map((section) => (
          <RoadmapRow
            id={`section-${section.num}`}
            href={`/roadmap/${section.slug}/`}
            num={section.num}
            name={section.name}
            status={section.status}
            goal={section.goal}
            done={section.done}
            total={section.total}
          />
        ))}
      </div>
    </section>

    <section class="lane lane-next">
      <header class="lane-header">
        <span class="lane-flag muted">Next</span>
        <h2>Planned</h2>
        <span class="lane-count">{plannedSections.length} sections</span>
      </header>
      <div class="lane-rows">
        {plannedSections.map((section) => (
          <RoadmapRow
            id={`section-${section.num}`}
            href={`/roadmap/${section.slug}/`}
            num={section.num}
            name={section.name}
            status={section.status}
            goal={section.goal}
            done={section.done}
            total={section.total}
          />
        ))}
      </div>
    </section>

    <section class="lane lane-shipped">
      <details>
        <summary class="lane-header">
          <span class="lane-flag success">Shipped</span>
          <h2>Completed</h2>
          <span class="lane-count">{completedSections.length} sections</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="lane-rows">
          {completedSections.map((section) => (
            <RoadmapRow
              id={`section-${section.num}`}
              href={`/roadmap/${section.slug}/`}
              num={section.num}
              name={section.name}
              status={section.status}
              goal={section.goal}
              done={section.done}
              total={section.total}
            />
          ))}
        </div>
      </details>
    </section>

    <section class="plans-section">
      <header class="plans-header">
        <h2>Feature &amp; Subsystem Plans</h2>
        <p class="plans-subtitle">
          Deeper workstreams that run alongside the roadmap — performance engineering,
          memory-system upgrades, new language features, and backend work.
        </p>
      </header>
      {activePlans.length > 0 && (
        <div class="plan-group">
          <h3 class="plan-group-label warning">Active</h3>
          <div class="lane-rows">
            {activePlans.map(p => (
              <a class="plan-row active" href={`/roadmap/plans/${p.key}/`}>
                <span class="row-marker" aria-hidden="true"></span>
                <span class="plan-row-name">{p.name}</span>
                <span class="plan-row-full">{p.fullName !== p.name ? p.fullName : ''}</span>
                <span class="row-chip partial">Active</span>
              </a>
            ))}
          </div>
        </div>
      )}
      {queuedPlans.length > 0 && (
        <div class="plan-group">
          <h3 class="plan-group-label muted">Queued</h3>
          <div class="lane-rows">
            {queuedPlans.map(p => (
              <a class="plan-row queued" href={`/roadmap/plans/${p.key}/`}>
                <span class="row-marker" aria-hidden="true"></span>
                <span class="plan-row-name">{p.name}</span>
                <span class="plan-row-full">{p.fullName !== p.name ? p.fullName : ''}</span>
                <span class="row-chip not-started">Queued</span>
              </a>
            ))}
          </div>
        </div>
      )}
      {shippedPlans.length > 0 && (
        <details class="plan-group">
          <summary class="plan-group-summary">
            <h3 class="plan-group-label success">Shipped</h3>
            <span class="lane-count">{shippedPlans.length} plans</span>
            <span class="expand-icon"></span>
          </summary>
          <div class="lane-rows">
            {shippedPlans.map(p => (
              <a class="plan-row resolved" href={`/roadmap/plans/${p.key}/`}>
                <span class="row-marker" aria-hidden="true"></span>
                <span class="plan-row-name">{p.name}</span>
                <span class="plan-row-full">{p.fullName !== p.name ? p.fullName : ''}</span>
                <span class="row-chip complete">Shipped</span>
              </a>
            ))}
          </div>
        </details>
      )}
    </section>

    <section class="test-results">
      <div class="test-results-header">
        <h2>Current Test Results</h2>
        <span class="test-results-date">
          {testResults.timestamp
            ? new Date(testResults.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
            : 'Latest CI run'}
        </span>
      </div>
      {testResults.suites.length > 0 ? (
        <>
          <div class="results-grid">
            {testResults.suites.map((suite) => {
              const isStatusOnly = suite.passed === null;
              const isCrashed = suite.status === 'crashed';
              const hasFailed = (suite.failed ?? 0) > 0;
              const borderClass = isCrashed ? 'crashed' : hasFailed ? 'has-failures' : '';
              return (
                <div class={`result-card ${borderClass}`}>
                  {isCrashed ? (
                    <span class="result-value result-value-status">CRASHED</span>
                  ) : isStatusOnly ? (
                    <span class="result-value result-value-status">{(suite.status ?? 'unknown').toUpperCase()}</span>
                  ) : (
                    <span class="result-value">{(suite.passed ?? 0).toLocaleString()}</span>
                  )}
                  <span class="result-label">{suite.name}</span>
                  <div class="result-details">
                    {isCrashed ? (
                      <span class="result-status failing">Crashed</span>
                    ) : isStatusOnly ? (
                      <span class={`result-status ${suite.status === 'passed' ? 'success' : suite.status === 'skipped' ? 'muted' : 'failing'}`}>
                        {suite.status === 'passed' ? 'Passed' : suite.status === 'skipped' ? 'Skipped' : 'Failed'}
                      </span>
                    ) : (
                      <>
                        <span class={`result-status ${hasFailed ? 'failing' : 'success'}`}>
                          {hasFailed ? `${suite.failed} Failing` : 'All Passing'}
                        </span>
                        {(suite.skipped ?? 0) > 0 && (
                          <span class="result-status muted">{suite.skipped} Skipped</span>
                        )}
                        {(suite.lcfail ?? 0) > 0 && (
                          <span class="result-status lcfail">{(suite.lcfail ?? 0).toLocaleString()} LC Fail</span>
                        )}
                      </>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
          <div class="results-total">
            <span class="results-total-label">Total</span>
            <span class="results-total-value">{testResults.totals.passed.toLocaleString()} passed</span>
            {testResults.totals.failed > 0 && (
              <span class="results-total-value failing">{testResults.totals.failed.toLocaleString()} failed</span>
            )}
            {testResults.totals.skipped > 0 && (
              <span class="results-total-value muted">{testResults.totals.skipped.toLocaleString()} skipped</span>
            )}
            {testResults.totals.lcfail > 0 && (
              <span class="results-total-value lcfail">{testResults.totals.lcfail.toLocaleString()} LC fail</span>
            )}
          </div>
        </>
      ) : (
        <p class="test-results-subtitle">No test results available yet.</p>
      )}
    </section>

    <section class="proposals-section">
      <h2>Language Proposals</h2>
      <p class="proposals-subtitle">
        Design decisions and rationale for language features. Proposals go through draft review before approval or rejection.
      </p>
      <div class="proposal-stats">
        <span class="proposal-stat approved">{approvedCount} approved</span>
        <span class="proposal-stat draft">{draftCount} drafts</span>
        <span class="proposal-stat rejected">{rejectedCount} rejected</span>
      </div>
      <a href="/proposals/" class="btn btn-secondary">View all proposals <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12" fill="currentColor" style="vertical-align: -0.125em" aria-hidden="true"><path d="M502.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L402.7 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l370.7 0-105.4 105.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z"/></svg></a>
    </section>

    <section class="roadmap-cta">
      <h2>Follow along</h2>
      <p>The compiler is developed in the open — releases, changelog, and source live on GitHub.</p>
      <div class="cta-buttons">
        <a href="https://github.com/upstat-io/ori-lang" class="btn btn-primary" target="_blank" rel="noopener">GitHub</a>
        <a href="/changelog/" class="btn btn-secondary">Changelog</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .roadmap-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .roadmap-hero {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .roadmap-hero h1 {
    font-size: var(--text-5xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .roadmap-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  /* Overall progress */
  .hero-progress {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    column-gap: var(--space-3);
    max-width: 640px;
    margin: 0 auto var(--space-8);
    text-align: left;
  }

  .hero-progress-meta {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-2);
  }

  .hero-progress-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
  }

  .hero-progress-numbers {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .hero-progress-bar {
    height: 10px;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .hero-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--sage-500), var(--sage-300));
    border-radius: var(--radius-full);
    transition: width var(--transition-medium);
  }

  .hero-progress-text {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
    background: var(--glass-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4) var(--space-6);
    width: 140px;
  }

  .stat-value {
    display: block;
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    margin-bottom: var(--space-1);
  }

  .stat-value.warning { color: var(--color-warning); }
  .stat-value.success { color: var(--color-success); }
  .stat-value.muted { color: var(--color-text-secondary); }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Timeline Minimap */
  .timeline-section {
    margin-bottom: var(--space-8);
  }

  /* Lanes */
  .lane {
    margin-bottom: var(--space-6);
  }

  .lane-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    margin-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    list-style: none;
  }

  .lane-header::-webkit-details-marker {
    display: none;
  }

  .lane-header h2 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 0;
  }

  .lane-flag {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 10px;
    border-radius: var(--radius-full);
  }

  .lane-flag.warning {
    background: var(--color-primary-subtle);
    color: var(--color-warning);
    border: 1px solid var(--color-warning);
  }

  .lane-flag.muted {
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .lane-flag.success {
    background: var(--color-accent-subtle);
    color: var(--color-success);
    border: 1px solid var(--color-success);
  }

  .lane-count {
    margin-left: auto;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .lane-rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .lane-shipped summary {
    cursor: pointer;
  }

  .expand-icon {
    width: 20px;
    height: 20px;
    position: relative;
    color: var(--color-text-muted);
  }

  .expand-icon::before {
    content: "\25B8";
    font-size: var(--text-sm);
    transition: transform 0.2s ease;
    display: inline-block;
  }

  details[open] .expand-icon::before {
    transform: rotate(90deg);
  }

  details[open] > summary {
    margin-bottom: var(--space-2);
  }

  /* Plans section */
  .plans-section {
    margin-top: var(--space-12);
  }

  .plans-header h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-1);
  }

  .plans-subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-5);
    max-width: 70ch;
  }

  .plan-group {
    margin-bottom: var(--space-5);
  }

  .plan-group-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-2);
  }

  .plan-group-label.warning { color: var(--color-warning); }
  .plan-group-label.muted { color: var(--color-text-muted); }
  .plan-group-label.success { color: var(--color-success); }

  .plan-group-summary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    cursor: pointer;
    list-style: none;
    padding: var(--space-2) 0;
  }

  .plan-group-summary::-webkit-details-marker {
    display: none;
  }

  .plan-group-summary .plan-group-label {
    margin: 0;
  }

  .plan-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-left-width: 3px;
    background: var(--color-bg-secondary);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .plan-row:hover {
    background: var(--color-bg-tertiary);
    border-color: var(--color-border-hover);
  }

  .plan-row.active { border-left-color: var(--color-warning); }
  .plan-row.queued { border-left-color: var(--color-text-muted); }
  .plan-row.resolved { border-left-color: var(--color-success); opacity: 0.85; }

  .plan-row .row-marker {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .plan-row.active .row-marker { background: var(--color-warning); }
  .plan-row.queued .row-marker { background: transparent; border: 2px solid var(--color-text-muted); }
  .plan-row.resolved .row-marker { background: var(--color-success); }

  .plan-row-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .plan-row-full {
    flex: 1;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .row-chip {
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    padding: 1px 8px;
    border-radius: var(--radius-full);
  }

  .row-chip.complete {
    background: var(--color-accent-subtle);
    color: var(--color-success);
  }

  .row-chip.partial {
