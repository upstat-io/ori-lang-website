---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionCard from '../../components/SectionCard.astro';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { join } from 'path';
import { loadAllSections, countTasks, reroutes, parallelPlans } from '../../lib/plan-data';
import type { RoadmapSection, Section } from '../../lib/plan-data';
import TimelineMinimap from '../../components/TimelineMinimap.astro';

const roadmapDir = join(process.cwd(), '..', 'ori_lang', 'plans', 'roadmap');
const allSections: RoadmapSection[] = loadAllSections(roadmapDir);

// Group sections by status for the collapsible groups
const completedSections = allSections.filter(s => s.status === "complete");
const inProgressSections = allSections.filter(s => s.status === "partial");
const plannedSections = allSections.filter(s => s.status === "not-started");

// Accumulate total progress across all sections
const totalProgress = allSections.reduce(
  (acc, section) => {
    const { done, total } = countTasks(section.subsections, section.status);
    return { done: acc.done + done, total: acc.total + total };
  },
  { done: 0, total: 0 },
);

// Load test results from CI
interface TestSuite {
  name: string;
  status?: string;        // "passed" | "failed" | "skipped" | "crashed" (for non-numeric suites like WASM)
  passed: number | null;
  failed: number | null;
  skipped: number | null;
  lcfail: number | null;  // LLVM compile failures
}

interface TestResults {
  timestamp?: string;
  overall?: string;
  suites: TestSuite[];
  totals: { passed: number; failed: number; skipped: number; lcfail: number };
}

function loadTestResults(): TestResults {
  const testResultsPath = join(process.cwd(), 'public', 'test-results.json');
  const empty: TestResults = { suites: [], totals: { passed: 0, failed: 0, skipped: 0, lcfail: 0 } };

  if (!existsSync(testResultsPath)) {
    return empty;
  }

  try {
    const content = readFileSync(testResultsPath, 'utf-8');
    const data = JSON.parse(content);

    // New format — has "suites" array
    if (data.suites && Array.isArray(data.suites)) {
      return {
        timestamp: data.timestamp,
        overall: data.overall,
        suites: data.suites,
        totals: data.totals ?? { passed: 0, failed: 0, skipped: 0, lcfail: 0 },
      };
    }

    // Legacy format — flat { rust_tests, ori_tests, llvm_tests }
    const suites: TestSuite[] = [
      { name: 'Rust Unit Tests', passed: data.rust_tests ?? 0, failed: data.rust_failed ?? 0, skipped: null, lcfail: null },
      { name: 'Ori Spec Tests', passed: data.ori_tests ?? 0, failed: data.ori_failed ?? 0, skipped: null, lcfail: null },
      { name: 'LLVM Backend Tests', passed: data.llvm_tests ?? 0, failed: data.llvm_failed ?? 0, skipped: null, lcfail: null },
    ];
    const totalPassed = suites.reduce((s, t) => s + (t.passed ?? 0), 0);
    const totalFailed = suites.reduce((s, t) => s + (t.failed ?? 0), 0);
    return {
      timestamp: data.timestamp,
      overall: totalFailed > 0 ? 'failed' : 'passed',
      suites,
      totals: { passed: totalPassed, failed: totalFailed, skipped: 0, lcfail: 0 },
    };
  } catch {
    return empty;
  }
}

const testResults = loadTestResults();

// Proposal counts (lightweight — just count files, don't parse)
function countProposals(dir: string): number {
  const proposalsDir = join(process.cwd(), '..', 'ori_lang', 'docs', 'ori_lang', 'proposals', dir);
  if (!existsSync(proposalsDir)) return 0;
  return readdirSync(proposalsDir).filter(f => f.endsWith('.md')).length;
}

const approvedCount = countProposals('approved');
const draftCount = countProposals('drafts');
const rejectedCount = countProposals('rejected');
---

<BaseLayout
  title="Compiler Roadmap | OriLang"
  description={`OriLang compiler roadmap: ${allSections.length} sections. Track progress on type system, traits, capabilities, async, FFI, LLVM backend, and tooling.`}
  keywords="OriLang roadmap, compiler development, programming language, type system, async, FFI, LLVM, tooling, Ori compiler"
>
  <main class="roadmap-page">
    <section class="roadmap-hero">
      <h1 class="gradient-title">Compiler Roadmap</h1>
      <p class="roadmap-subtitle">
        {allSections.length} sections. Click any section to view full details.
      </p>
      <div class="stats">
        <div class="stat">
          <span class="stat-value">{completedSections.length}</span>
          <span class="stat-label">Completed</span>
        </div>
        <div class="stat">
          <span class="stat-value">{inProgressSections.length}</span>
          <span class="stat-label">In Progress</span>
        </div>
        <div class="stat">
          <span class="stat-value">{plannedSections.length}</span>
          <span class="stat-label">Planned</span>
        </div>
      </div>
      {totalProgress.total > 0 && (
        <div class="hero-progress">
          <div class="hero-progress-bar">
            <div class="hero-progress-fill" style={`width: ${(totalProgress.done / totalProgress.total) * 100}%`}></div>
          </div>
          <span class="hero-progress-text">{Math.round((totalProgress.done / totalProgress.total) * 100)}%</span>
        </div>
      )}
    </section>

    <section class="timeline-section">
      <TimelineMinimap
        nodes={allSections.map(s => ({
          label: `Section ${s.num}`,
          name: s.name,
          status: s.status,
          scrollTarget: `section-${s.num}`,
        }))}
        blockingTracks={reroutes.map(r => ({
          label: r.name,
          fullName: r.fullName,
          status: r.status,
          href: `/roadmap/plans/${r.key}/`,
        }))}
        parallelTracks={parallelPlans.map(p => ({
          label: p.name,
          fullName: p.fullName,
          status: p.status,
          href: `/roadmap/plans/${p.key}/`,
        }))}
      />
    </section>

    <section class="status-section in-progress-section">
      <details open>
        <summary class="status-header in-progress">
          <span class="status-icon">&cir;</span>
          <h2>In Progress</h2>
          <span class="status-count">{inProgressSections.length} sections</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="status-sections">
          {inProgressSections.map((section) => {
            const { done, total } = countTasks(section.subsections, section.status);
            return (
              <SectionCard
                id={`section-${section.num}`}
                href={`/roadmap/${section.slug}/`}
                num={section.num}
                name={section.name}
                status={section.status}
                note={section.note}
                goal={section.goal}
                done={done}
                total={total}
              />
            );
          })}
        </div>
      </details>
    </section>

    <section class="status-section planned-section">
      <details open>
        <summary class="status-header planned">
          <span class="status-icon">&cir;</span>
          <h2>Planned</h2>
          <span class="status-count">{plannedSections.length} sections</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="status-sections">
          {plannedSections.map((section) => {
            const { done, total } = countTasks(section.subsections, section.status);
            return (
              <SectionCard
                id={`section-${section.num}`}
                href={`/roadmap/${section.slug}/`}
                num={section.num}
                name={section.name}
                status={section.status}
                note={section.note}
                goal={section.goal}
                done={done}
                total={total}
              />
            );
          })}
        </div>
      </details>
    </section>

    <section class="status-section completed-section">
      <details>
        <summary class="status-header completed">
          <span class="status-icon">&check;</span>
          <h2>Completed</h2>
          <span class="status-count">{completedSections.length} sections</span>
          <span class="expand-icon"></span>
        </summary>
        <div class="status-sections">
          {completedSections.map((section) => {
            const { done, total } = countTasks(section.subsections, section.status);
            return (
              <SectionCard
                id={`section-${section.num}`}
                href={`/roadmap/${section.slug}/`}
                num={section.num}
                name={section.name}
                status={section.status}
                note={section.note}
                goal={section.goal}
                done={done}
                total={total}
              />
            );
          })}
        </div>
      </details>
    </section>

    <section class="test-results">
      <div class="test-results-header">
        <h2>Current Test Results</h2>
        <span class="test-results-date">
          {testResults.timestamp
            ? new Date(testResults.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
            : 'Latest CI run'}
        </span>
      </div>
      {testResults.suites.length > 0 ? (
        <>
          <div class="results-grid">
            {testResults.suites.map((suite) => {
              const isStatusOnly = suite.passed === null;
              const isCrashed = suite.status === 'crashed';
              const hasFailed = (suite.failed ?? 0) > 0;
              const borderClass = isCrashed ? 'crashed' : hasFailed ? 'has-failures' : '';
              return (
                <div class={`result-card ${borderClass}`}>
                  {isCrashed ? (
                    <span class="result-value result-value-status">CRASHED</span>
                  ) : isStatusOnly ? (
                    <span class="result-value result-value-status">{(suite.status ?? 'unknown').toUpperCase()}</span>
                  ) : (
                    <span class="result-value">{(suite.passed ?? 0).toLocaleString()}</span>
                  )}
                  <span class="result-label">{suite.name}</span>
                  <div class="result-details">
                    {isCrashed ? (
                      <span class="result-status failing">Crashed</span>
                    ) : isStatusOnly ? (
                      <span class={`result-status ${suite.status === 'passed' ? 'success' : suite.status === 'skipped' ? 'muted' : 'failing'}`}>
                        {suite.status === 'passed' ? 'Passed' : suite.status === 'skipped' ? 'Skipped' : 'Failed'}
                      </span>
                    ) : (
                      <>
                        <span class={`result-status ${hasFailed ? 'failing' : 'success'}`}>
                          {hasFailed ? `${suite.failed} Failing` : 'All Passing'}
                        </span>
                        {(suite.skipped ?? 0) > 0 && (
                          <span class="result-status muted">{suite.skipped} Skipped</span>
                        )}
                        {(suite.lcfail ?? 0) > 0 && (
                          <span class="result-status lcfail">{(suite.lcfail ?? 0).toLocaleString()} LC Fail</span>
                        )}
                      </>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
          <div class="results-total">
            <span class="results-total-label">Total</span>
            <span class="results-total-value">{testResults.totals.passed.toLocaleString()} passed</span>
            {testResults.totals.failed > 0 && (
              <span class="results-total-value failing">{testResults.totals.failed.toLocaleString()} failed</span>
            )}
            {testResults.totals.skipped > 0 && (
              <span class="results-total-value muted">{testResults.totals.skipped.toLocaleString()} skipped</span>
            )}
            {testResults.totals.lcfail > 0 && (
              <span class="results-total-value lcfail">{testResults.totals.lcfail.toLocaleString()} LC fail</span>
            )}
          </div>
        </>
      ) : (
        <p class="test-results-subtitle">No test results available yet.</p>
      )}
    </section>

    <section class="proposals-section">
      <h2>Language Proposals</h2>
      <p class="proposals-subtitle">
        Design decisions and rationale for language features. Proposals go through draft review before approval or rejection.
      </p>
      <div class="proposal-stats">
        <span class="proposal-stat approved">{approvedCount} approved</span>
        <span class="proposal-stat draft">{draftCount} drafts</span>
        <span class="proposal-stat rejected">{rejectedCount} rejected</span>
      </div>
      <a href="/proposals/" class="btn btn-secondary">View all proposals <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12" fill="currentColor" style="vertical-align: -0.125em" aria-hidden="true"><path d="M502.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L402.7 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l370.7 0-105.4 105.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z"/></svg></a>
    </section>

    <section class="roadmap-cta">
      <h2>Want to contribute?</h2>
      <p>The roadmap lives in <code>plans/roadmap/</code>. Each section has detailed implementation tasks.</p>
      <div class="cta-buttons">
        <a href="https://github.com/upstat-io/ori-lang/tree/master/plans/roadmap" class="btn btn-primary" target="_blank" rel="noopener">View Full Roadmap</a>
        <a href="https://github.com/upstat-io/ori-lang" class="btn btn-secondary" target="_blank" rel="noopener">GitHub</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .roadmap-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .roadmap-hero {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .roadmap-hero h1 {
    font-size: var(--text-5xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .roadmap-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
    background: var(--glass-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-8);
    width: 160px;
  }

  .stat-value {
    display: block;
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: var(--space-1);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Hero progress bar */
  .hero-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .hero-progress-bar {
    flex: 1;
    height: 8px;
    background: var(--color-bg-tertiary);
    border-radius: 9999px;
    overflow: hidden;
  }

  .hero-progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 9999px;
    transition: width var(--transition-base);
  }

  .hero-progress-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Status Sections (In Progress, Planned, Completed) */
  .status-section {
    margin-bottom: var(--space-4);
  }

  .status-section details {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  /* In Progress Section */
  .in-progress-section details {
    background: rgba(219, 132, 75, 0.02);
    border: 1px solid rgba(219, 132, 75, 0.15);
  }

  .in-progress-section details[open] {
    background: rgba(219, 132, 75, 0.03);
  }

  .status-header.in-progress h2 {
    color: var(--color-warning);
  }

  .status-header.in-progress .status-icon {
    background: rgba(219, 132, 75, 0.15);
    color: var(--color-warning);
  }

  .in-progress-section :global(.progress-fill) {
    background: var(--color-warning);
  }

  /* Planned Section */
  .planned-section details {
    background: rgba(164, 161, 157, 0.02);
    border: 1px solid rgba(164, 161, 157, 0.12);
  }

  .planned-section details[open] {
    background: rgba(164, 161, 157, 0.03);
  }

  .status-header.planned h2 {
    color: var(--color-text-secondary);
  }

  .status-header.planned .status-icon {
    background: rgba(164, 161, 157, 0.15);
    color: var(--color-text-secondary);
  }

  /* Completed Section */
  .completed-section details {
    background: rgba(116, 179, 176, 0.02);
    border: 1px solid rgba(116, 179, 176, 0.15);
  }

  .completed-section details[open] {
    background: rgba(116, 179, 176, 0.03);
  }

  .status-header.completed h2 {
    color: var(--color-success);
  }

  .status-header.completed .status-icon {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .completed-section :global(.progress-fill) {
    background: var(--color-success);
  }

  /* Common Status Header Styles */
  .status-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    list-style: none;
  }

  .status-header::-webkit-details-marker {
    display: none;
  }

  .status-header h2 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 0;
    flex: 1;
  }

  .status-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }

  .status-count {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .expand-icon {
    width: 20px;
    height: 20px;
    position: relative;
    color: var(--color-text-muted);
  }

  .expand-icon::before {
    content: "\25B8";
    font-size: var(--text-sm);
    transition: transform 0.2s ease;
    display: inline-block;
  }

  details[open] .expand-icon::before {
    transform: rotate(90deg);
  }

  .status-sections {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-3);
    padding: 0 var(--space-4) var(--space-4);
  }

  .status-section :global(.section-card) {
    background: var(--color-bg-secondary);
  }

  .status-section :global(.section-card:hover) {
    background: var(--color-bg-tertiary);
  }

  /* Timeline Minimap */
  .timeline-section {
    margin-bottom: var(--space-8);
  }

  /* Test Results */
  .test-results {
    margin-top: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .test-results-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .test-results h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin: 0;
  }

  .test-results-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .result-card {
    background: var(--glass-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    text-align: center;
  }

  .result-value {
    display: block;
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .result-label {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .result-status {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  .result-status.success {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .result-status.failing {
    background: rgba(232, 64, 64, 0.15);
    color: #d45a68;
  }

  .result-status.muted {
    background: var(--color-bg-tertiary);
    color: var(--color-text-muted);
  }

  .result-status.lcfail {
    background: rgba(219, 132, 75, 0.15);
    color: var(--color-warning);
  }

  .result-details {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: center;
  }

  .result-value-status {
    font-size: var(--text-xl);
  }

  .result-card.crashed {
    border-color: #d45a68;
  }

  .result-card.has-failures {
    border-color: #d45a68;
  }

  .results-total {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-5);
    background: var(--glass-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .results-total-label {
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  .results-total-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-success);
    font-weight: var(--weight-medium);
  }

  .results-total-value.failing {
    color: #d45a68;
  }

  .results-total-value.muted {
    color: var(--color-text-muted);
  }

  .results-total-value.lcfail {
    color: var(--color-warning);
  }

  .test-results-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  /* CTA */
  .roadmap-cta {
    text-align: center;
    padding: var(--space-12) var(--space-6);
    background: var(--glass-bg-alt);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  .roadmap-cta h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .roadmap-cta p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .roadmap-cta code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: var(--color-bg-code);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--color-accent);
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: all var(--transition-medium);
  }

