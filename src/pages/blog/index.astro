---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latest = posts[0];
const older = posts.slice(1);

function formatDate(date: Date): string {
  const months = ['January', 'February', 'March', 'April', 'May', 'June',
                  'July', 'August', 'September', 'October', 'November', 'December'];
  return `${months[date.getUTCMonth()]} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;
}
---

<BaseLayout
  title="Blog — Ori"
  description="Updates on the Ori programming language: design decisions, compiler progress, and release notes."
  keywords="Ori blog, programming language, compiler updates"
>
  <div class="blog-page">
    <header class="blog-header">
      <h1>Blog</h1>
      <p class="blog-subtitle">Updates on language design, compiler progress, and release notes.</p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-empty">No posts yet. Check back soon.</p>
    ) : (
      <>
        <a href={`/blog/${latest.id}/`} class="featured-post">
          <time datetime={latest.data.date.toISOString()}>{formatDate(latest.data.date)}</time>
          <h2>{latest.data.title}</h2>
          <p>{latest.data.description}</p>
        </a>

        {older.length > 0 && (
          <section class="older-posts">
            {older.map((post) => (
              <a href={`/blog/${post.id}/`} class="post-row">
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                <span class="post-title">{post.data.title}</span>
              </a>
            ))}
          </section>
        )}
      </>
    )}
  </div>
</BaseLayout>

<style>
  .blog-page {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .blog-header {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: var(--space-8);
  }

  .blog-header h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .blog-subtitle {
    color: var(--color-text-secondary);
  }

  .blog-empty {
    color: var(--color-text-muted);
    padding: var(--space-8) 0;
  }

  /* Featured latest post */
  .featured-post {
    display: block;
    padding: var(--space-6);
    border: 1px solid var(--glass-border);
    background: var(--color-bg-secondary);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: border-color var(--transition-fast);
  }

  .featured-post:hover {
    border-color: var(--glass-border-hover);
  }

  .featured-post time {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .featured-post h2 {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .featured-post p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Older posts list */
  .older-posts {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--glass-border);
  }

  .post-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-6);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--glass-border);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .post-row:hover .post-title {
    color: var(--sage-300);
  }

  .post-row time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 140px;
  }

  .post-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }

  @media (max-width: 640px) {
    .post-row {
      flex-direction: column;
      gap: var(--space-1);
    }

    .post-row time {
      min-width: auto;
    }
  }
</style>
