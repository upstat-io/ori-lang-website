---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, readingTime, excerpt } from '../../lib/blog';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latest = posts[0];
const older = posts.slice(1);

// Group the non-featured posts by year for the archive rail.
const byYear = new Map<number, typeof older>();
for (const post of older) {
  const y = post.data.date.getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout
  title="Devlog — OriLang Compiler & Language Updates"
  description="The OriLang devlog: compiler progress, language design decisions, memory-system deep dives, and honest notes from building a language."
  keywords="OriLang blog, Ori programming language updates, compiler development, language design, LLVM, ARC, AIMS"
>
  <div class="blog-page">
    <header class="blog-header">
      <span class="blog-tag">Devlog</span>
      <h1>Notes from building Ori</h1>
      <p class="blog-subtitle">
        Compiler progress, design decisions, and the occasional war story.
        Written by the person fixing the bugs.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-empty">No posts yet. Check back soon.</p>
    ) : (
      <>
        <a href={`/blog/${latest.id}/`} class="featured-post">
          <div class="featured-meta">
            <span class="featured-label">Latest</span>
            <time datetime={latest.data.date.toISOString()}>{formatDate(latest.data.date)}</time>
            <span class="meta-dot" aria-hidden="true"></span>
            <span class="read-time">{readingTime(latest.body)} min read</span>
          </div>
          <h2>{latest.data.title}</h2>
          <p class="featured-description">{latest.data.description}</p>
          <p class="featured-excerpt">{excerpt(latest.body)}</p>
          <span class="featured-cta">Read the post<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="11" height="11" fill="currentColor" aria-hidden="true"><path d="M502.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L402.7 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l370.7 0-105.4 105.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z"/></svg></span>
        </a>

        {years.map((year) => (
          <section class="year-group">
            <h3 class="year-label">{year}</h3>
            <div class="year-posts">
              {byYear.get(year)!.map((post) => (
                <a href={`/blog/${post.id}/`} class="post-card">
                  <div class="post-meta">
                    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                    <span class="meta-dot" aria-hidden="true"></span>
                    <span class="read-time">{readingTime(post.body)} min read</span>
                  </div>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-description">{post.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        ))}
      </>
    )}
  </div>
</BaseLayout>

<style>
  .blog-page {
    max-width: 880px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  /* ── Header ── */
  .blog-header {
    padding: var(--space-12) 0 var(--space-10);
  }

  .blog-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--copper-400);
    margin-bottom: var(--space-3);
  }

  .blog-header h1 {
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }

  .blog-subtitle {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    max-width: 52ch;
  }

  .blog-empty {
    color: var(--color-text-muted);
    padding: var(--space-8) 0;
  }

  /* ── Shared meta row ── */
  .featured-meta,
  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
  }

  .featured-meta time,
  .post-meta time {
    color: var(--copper-400);
  }

  .read-time {
    color: var(--color-text-muted);
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ── Featured (latest) post ── */
  .featured-post {
    position: relative;
    display: block;
    padding: var(--space-8);
    border: 1px solid var(--glass-border);
    background: var(--color-bg-secondary);
    text-decoration: none;
    margin-bottom: var(--space-12);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    overflow: hidden;
  }

  /* dual-hue hairline along the top edge — the house signature */
  .featured-post::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--copper-400), var(--sage-300));
  }

  .featured-post:hover {
    border-color: var(--glass-border-hover);
    background: var(--color-bg-tertiary);
  }

  .featured-label {
    color: var(--sage-300);
    text-transform: uppercase;
    font-weight: var(--weight-semibold);
  }

  .featured-post h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: var(--space-4) 0 var(--space-3);
  }

  .featured-description {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    max-width: 64ch;
  }

  .featured-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-4);
    border-left: 2px solid var(--sage-700);
    margin-bottom: var(--space-5);
    max-width: 62ch;
  }

  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sage-300);
  }

  .featured-post:hover .featured-cta {
    color: var(--sage-200);
  }

  /* ── Year archive ── */
  .year-group {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .year-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    padding-top: var(--space-5);
    margin: 0;
  }

  .year-posts {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--glass-border);
  }

  .post-card {
    display: block;
    padding: var(--space-5) var(--space-4);
    border-bottom: 1px solid var(--glass-border);
    border-left: 2px solid transparent;
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .post-card:hover {
    background: var(--color-bg-secondary);
    border-left-color: var(--sage-400);
  }

  .post-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin: var(--space-2) 0;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-title {
    color: var(--sage-300);
  }

  .post-description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 64ch;
  }

  @media (max-width: 640px) {
    .year-group {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .year-label {
      padding-top: 0;
    }

    .featured-post {
      padding: var(--space-5);
    }
  }
</style>
