---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function formatDate(date: Date): string {
  const months = ['January', 'February', 'March', 'April', 'May', 'June',
                  'July', 'August', 'September', 'October', 'November', 'December'];
  return `${months[date.getUTCMonth()]} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;
}

const currentPath = Astro.url.pathname;
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: entry.data.title, url: currentPath },
];
---

<BaseLayout
  title={`${entry.data.title} | OriLang Blog`}
  description={entry.data.description}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  <main class="blog-post-page">
    <section class="post-hero">
      <a href="/blog/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12" fill="currentColor" style="vertical-align: -0.125em" aria-hidden="true"><path d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 288 480 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-370.7 0 105.4-105.4c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/></svg>
        Blog
      </a>
      <h1 class="gradient-title">{entry.data.title}</h1>
      <p class="hero-description">{entry.data.description}</p>
      <time class="hero-date" datetime={entry.data.date.toISOString()}>
        {formatDate(entry.data.date)}
      </time>
    </section>

    <article class="post-article">
      <Content />
    </article>
  </main>
</BaseLayout>

<style>
  .blog-post-page {
    max-width: var(--max-width-narrow, 800px);
    margin: 0 auto;
    padding: var(--space-6) var(--space-8);
  }

  /* Hero */
  .post-hero {
    padding: var(--space-8) 0 var(--space-6);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-hero h1 {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
    line-height: 1.15;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed, 1.65);
  }

  .hero-date {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Article typography — matches DetailLayout */
  .post-article {
    line-height: var(--leading-relaxed, 1.65);
  }

  .post-article :global(h1) {
    margin-bottom: var(--space-6, 1.5rem);
  }

  .post-article :global(h2) {
    margin-top: var(--space-10, 2.5rem);
    margin-bottom: var(--space-4, 1rem);
    padding-bottom: var(--space-2, 0.5rem);
    border-bottom: 1px solid var(--color-border, #30333a);
  }

  .post-article :global(h3) {
    margin-top: var(--space-8, 2rem);
    margin-bottom: var(--space-3, 0.75rem);
  }

  .post-article :global(p) {
    margin-bottom: var(--space-4, 1rem);
  }

  .post-article :global(ul) {
    margin-bottom: var(--space-4, 1rem);
    list-style-type: disc !important;
    list-style-position: outside;
    padding-left: var(--space-6, 1.5rem);
  }

  .post-article :global(ol) {
    margin-bottom: var(--space-4, 1rem);
    list-style-type: decimal !important;
    list-style-position: outside;
    padding-left: var(--space-6, 1.5rem);
  }

  .post-article :global(li) {
    display: list-item;
  }

  .post-article :global(pre) {
    margin-bottom: var(--space-4, 1rem);
  }

  .post-article :global(table) {
    margin-bottom: var(--space-4, 1rem);
    font-size: var(--text-sm, 0.875rem);
  }

  .post-article :global(blockquote) {
    margin-bottom: var(--space-4, 1rem);
    padding-left: var(--space-4, 1rem);
    border-left: 3px solid var(--color-border, #30333a);
    color: var(--color-text-secondary);
  }

  .post-article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-bg-code, rgba(22, 22, 22, 0.3));
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }

  .post-article :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .post-article :global(strong) {
    font-weight: var(--weight-semibold, 600);
    color: var(--color-text-primary);
  }

  .post-article :global(em) {
    color: var(--color-text-secondary);
  }

  .post-article :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-article :global(a:hover) {
    text-decoration: underline;
  }

  .post-article :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  @media (max-width: 768px) {
    .blog-post-page {
      padding: var(--space-4, 1rem);
    }

    .post-hero h1 {
      font-size: var(--text-3xl);
    }
  }
</style>
