---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JourneyCard from '../../components/journeys/JourneyCard.astro';
import { getCollection } from 'astro:content';

const allJourneys = await getCollection('journeys');
const journeys = allJourneys.sort((a, b) => a.data.journey - b.data.journey);

const totalJourneys = journeys.length;
const passing = journeys.filter(j => j.data.status === 'PASS').length;
const avgScore = totalJourneys > 0
  ? (journeys.reduce((sum, j) => sum + j.data.score, 0) / totalJourneys).toFixed(1)
  : '0';
const totalBugs = journeys.reduce((sum, j) => sum + j.data.bugs_found.length, 0);

const simpleCount = journeys.filter(j => j.data.difficulty === 'simple').length;
const moderateCount = journeys.filter(j => j.data.difficulty === 'moderate').length;
const complexCount = journeys.filter(j => j.data.difficulty === 'complex').length;

const allFeatures = [...new Set(journeys.flatMap(j => j.data.features))].sort();

const lastJourneyDate = totalJourneys > 0
  ? new Date(Math.max(...journeys.map(j => j.data.date.getTime()))).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : null;
---

<BaseLayout
  title="Code Journeys — Ori"
  description={`${totalJourneys} interactive journeys through the Ori compiler pipeline. Watch real code travel from source to binary, phase by phase.`}
  keywords="Ori compiler, code journey, compiler pipeline, LLVM, codegen analysis, educational"
>
  <main class="journeys-page">
    <section class="journeys-hero">
      <h1 class="gradient-title">Code Journeys</h1>
      <p class="journeys-subtitle">
        Watch real Ori programs travel through the compiler pipeline — from source code to binary.
        Each journey traces lexing, parsing, type checking, ARC analysis, and codegen, exposing
        exactly what the compiler does at every phase.
      </p>
      <a href="/journeys/what-is-a-journey/" class="explainer-link">What is a Code Journey?</a>
      <div class="stats">
        <div class="stat">
          <span class="stat-value">{totalJourneys}</span>
          <span class="stat-label">Journeys</span>
        </div>
        <div class="stat">
          <span class="stat-value">{passing}/{totalJourneys}</span>
          <span class="stat-label">Passing</span>
        </div>
        <div class="stat">
          <span class="stat-value">{avgScore}</span>
          <span class="stat-label">Avg Score</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalBugs}</span>
          <span class="stat-label">Bugs Found</span>
        </div>
        {lastJourneyDate && (
          <div class="stat">
            <span class="stat-value">{lastJourneyDate}</span>
            <span class="stat-label">Last Journey</span>
          </div>
        )}
      </div>
    </section>

    <section class="difficulty-overview">
      <div class="difficulty-bar">
        {simpleCount > 0 && (
          <div class="difficulty-segment simple" style={`flex: ${simpleCount}`}>
            <span>{simpleCount} Simple</span>
          </div>
        )}
        {moderateCount > 0 && (
          <div class="difficulty-segment moderate" style={`flex: ${moderateCount}`}>
            <span>{moderateCount} Moderate</span>
          </div>
        )}
        {complexCount > 0 && (
          <div class="difficulty-segment complex" style={`flex: ${complexCount}`}>
            <span>{complexCount} Complex</span>
          </div>
        )}
      </div>
    </section>

    {journeys.length === 0 ? (
      <p class="journeys-empty">No journeys yet. Check back soon.</p>
    ) : (
      <section class="journey-grid">
        {journeys.map((j) => (
          <JourneyCard
            journey={j.data.journey}
            slug={j.data.slug}
            theme={j.data.theme}
            difficulty={j.data.difficulty}
            score={j.data.score}
            status={j.data.status}
            features={j.data.features}
            featureDescription={j.data.feature_description}
            bugsFound={j.data.bugs_found.length}
          />
        ))}
      </section>
    )}

    <section class="features-section">
      <h2>Features Covered</h2>
      <div class="feature-cloud">
        {allFeatures.map(f => (
          <span class="feature-pill">{f.replace(/_/g, ' ')}</span>
        ))}
      </div>
    </section>

    <section class="journeys-cta">
      <h2>How it works</h2>
      <div class="pipeline-preview">
        <div class="pipeline-step">
          <span class="step-number">1</span>
          <span class="step-name">Source</span>
        </div>
        <span class="pipeline-arrow">&#x2192;</span>
        <div class="pipeline-step">
          <span class="step-number">2</span>
          <span class="step-name">Lexer</span>
        </div>
        <span class="pipeline-arrow">&#x2192;</span>
        <div class="pipeline-step">
          <span class="step-number">3</span>
          <span class="step-name">Parser</span>
        </div>
        <span class="pipeline-arrow">&#x2192;</span>
        <div class="pipeline-step">
          <span class="step-number">4</span>
          <span class="step-name">Type Check</span>
        </div>
        <span class="pipeline-arrow">&#x2192;</span>
        <div class="pipeline-step">
          <span class="step-number">5</span>
          <span class="step-name">ARC</span>
        </div>
        <span class="pipeline-arrow">&#x2192;</span>
        <div class="pipeline-step">
          <span class="step-number">6</span>
          <span class="step-name">Codegen</span>
        </div>
      </div>
      <p class="cta-description">
        Each journey follows an Ori program through every compiler phase.
        Click any journey above to see the full pipeline analysis.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .journeys-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
  }

  .journeys-hero {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .journeys-hero h1 {
    font-size: var(--text-5xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .journeys-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0 auto var(--space-4);
    line-height: 1.6;
  }

  .explainer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-8);
    transition: all var(--transition-medium);
  }

  .explainer-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(126, 183, 166, 0.08);
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
    background: var(--glass-bg-alt);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4) var(--space-6);
    min-width: 120px;
    transition: border-color var(--transition-medium), transform var(--transition-medium);
  }

  .stat:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .stat-value {
    display: block;
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: var(--space-1);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Difficulty overview bar */
  .difficulty-overview {
    margin-bottom: var(--space-8);
  }

  .difficulty-bar {
    display: flex;
    gap: 2px;
    border-radius: var(--radius-md);
    overflow: hidden;
    height: 32px;
  }

  .difficulty-segment {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
  }

  .difficulty-segment.simple {
    background: rgba(144, 143, 139, 0.15);
    color: var(--color-text-muted);
  }

  .difficulty-segment.moderate {
    background: rgba(126, 183, 166, 0.2);
    color: var(--color-accent);
  }

  .difficulty-segment.complex {
    background: rgba(209, 168, 71, 0.2);
    color: var(--color-primary);
  }

  /* Journey card grid */
  .journey-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .journeys-empty {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    padding: var(--space-8) 0;
  }

  /* Features cloud */
  .features-section {
    margin-bottom: var(--space-12);
  }

  .features-section h2 {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
    text-align: center;
  }

  .feature-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }

  .feature-pill {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full, 9999px);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  /* Pipeline preview CTA */
  .journeys-cta {
    text-align: center;
    padding: var(--space-10) var(--space-6);
    background: var(--glass-bg-alt);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  .journeys-cta h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .pipeline-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .pipeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    min-width: 80px;
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
  }

  .step-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
  }

  .pipeline-arrow {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  .cta-description {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .journeys-hero h1 {
      font-size: var(--text-4xl);
    }

    .stats {
      gap: var(--space-3);
    }

    .stat {
      min-width: 100px;
      padding: var(--space-3) var(--space-4);
    }

    .stat-value {
      font-size: var(--text-2xl);
    }

    .journey-grid {
      grid-template-columns: 1fr;
    }

    .pipeline-preview {
      gap: var(--space-1);
    }

    .pipeline-step {
      min-width: 60px;
      padding: var(--space-2) var(--space-3);
    }

    .step-name {
      font-size: var(--text-xs);
    }

    .pipeline-arrow {
      font-size: var(--text-sm);
    }
  }
</style>
