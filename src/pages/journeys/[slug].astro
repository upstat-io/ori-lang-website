---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const journeys = await getCollection('journeys');
  return journeys.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Map score_breakdown keys to keywords found in Deep Scrutiny headings
const scoreKeywords: Record<string, string[]> = {
  instruction_efficiency: ['instruction purity', 'instruction'],
  arc_correctness: ['arc purity', 'arc'],
  attributes_safety: ['attributes', 'calling convention'],
  control_flow: ['control flow'],
  ir_quality: ['optimal ir'],
  binary_quality: ['binary analysis'],
};

// Build a map from score key → heading slug by matching keywords in h3 headings
const scoreAnchors: Record<string, string> = {};
for (const [key, keywords] of Object.entries(scoreKeywords)) {
  const h3s = headings.filter(h => h.depth === 3);
  const match = h3s.find(h => {
    const lower = h.text.toLowerCase();
    return keywords.some(kw => lower.includes(kw));
  });
  if (match) {
    scoreAnchors[key] = `#${match.slug}`;
  }
}

const d = entry.data;
const scoreColor = d.score >= 9 ? 'var(--color-success)' :
                   d.score >= 7 ? 'var(--color-accent)' :
                   d.score >= 5 ? 'var(--color-warning)' :
                   'var(--color-error, #e84040)';

const difficultyLabel = { simple: 'Simple', moderate: 'Moderate', complex: 'Complex' }[d.difficulty];
const difficultyColor = { simple: 'var(--color-text-muted)', moderate: 'var(--color-accent)', complex: 'var(--color-primary)' }[d.difficulty];

const statusPassed = d.status === 'PASS';
const openBugs = d.bugs_found.filter(b => b.status === 'OPEN').length;

function formatDate(date: Date): string {
  const months = ['January', 'February', 'March', 'April', 'May', 'June',
                  'July', 'August', 'September', 'October', 'November', 'December'];
  return `${months[date.getUTCMonth()]} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;
}

// Resolve pipeline phase anchors from actual headings in the markdown
const phaseDefinitions = [
  { keywords: ['source'],          name: 'Source',       icon: '1',  depths: [2] },
  { keywords: ['lexer'],           name: 'Lexer',        icon: '2',  depths: [3] },
  { keywords: ['parser'],          name: 'Parser',       icon: '3',  depths: [3] },
  { keywords: ['type checker'],    name: 'Type Checker', icon: '4',  depths: [3] },
  { keywords: ['canonicalization'],name: 'Canon',        icon: '5',  depths: [3] },
  { keywords: ['arc pipeline', 'arc'],name: 'ARC',       icon: '6',  depths: [3] },
  { keywords: ['interpreter', 'eval'],name: 'Eval',      icon: '7a', depths: [3] },
  { keywords: ['llvm'],            name: 'LLVM',         icon: '7b', depths: [3] },
];

const pipelinePhases = phaseDefinitions.map(phase => {
  const match = headings.find(h =>
    phase.depths.includes(h.depth) &&
    phase.keywords.some(kw => h.text.toLowerCase().includes(kw))
  );
  return { ...phase, anchor: match ? `#${match.slug}` : undefined };
}).filter(p => p.anchor);

const currentPath = Astro.url.pathname;
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Journeys', url: '/journeys/' },
  { name: `#${String(d.journey).padStart(2, '0')}: ${d.theme}`, url: currentPath },
];
---

<BaseLayout
  title={`Journey ${d.journey}: ${d.theme} — Ori`}
  description={d.feature_description}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  <main class="journey-page">
    <section class="journey-hero">
      <a href="/journeys/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12" fill="currentColor" style="vertical-align: -0.125em" aria-hidden="true"><path d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 288 480 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-370.7 0 105.4-105.4c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/></svg>
        All Journeys
      </a>
      <div class="hero-top">
        <span class="journey-number">Journey #{String(d.journey).padStart(2, '0')}</span>
        <span class="difficulty-badge" style={`--badge-color: ${difficultyColor}`}>{difficultyLabel}</span>
      </div>
      <h1 class="gradient-title">{d.theme}</h1>
      <p class="hero-description">{d.feature_description}</p>
      <time class="hero-date" datetime={d.date.toISOString()}>
        {formatDate(d.date)}
      </time>

      <div class="hero-meta">
        <div class="meta-item">
          <div class="score-ring-lg">
            <svg viewBox="0 0 36 36">
              <path class="score-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
              <path class="score-fill" style={`stroke: ${scoreColor}; stroke-dasharray: ${d.score * 10}, 100`}
                d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            </svg>
            <span class="score-value-lg" style={`color: ${scoreColor}`}>{d.score}</span>
          </div>
          <span class="meta-label">Score</span>
        </div>
        <div class="meta-item">
          <span class={`status-badge ${statusPassed ? 'pass' : 'fail'}`}>
            {d.status}
          </span>
          <span class="meta-label">Status</span>
        </div>
        <div class="meta-item">
          <span class="meta-value">{d.expected}</span>
          <span class="meta-label">Expected</span>
        </div>
        <div class="meta-item">
          <span class={`overflow-badge ${d.overflow_check === 'PASS' ? 'pass' : 'fail'}`}>
            {d.overflow_check}
          </span>
          <span class="meta-label">Overflow</span>
        </div>
        {d.bugs_found.length > 0 && (
          <div class="meta-item">
            <span class="meta-value bugs">{d.bugs_found.length}{openBugs > 0 ? ` (${openBugs} open)` : ''}</span>
            <span class="meta-label">Bugs</span>
          </div>
        )}
      </div>
    </section>

    {d.learning_objectives.length > 0 && (
      <section class="learning-objectives">
        <h2>What you'll learn</h2>
        <ul>
          {d.learning_objectives.map(obj => (
            <li>{obj}</li>
          ))}
        </ul>
      </section>
    )}

    <section class="score-breakdown-section">
      <h2>Score Breakdown</h2>
      <div class="breakdown-grid">
        {Object.entries(d.score_breakdown).map(([key, value]) => {
          const label = key.replace(/_/g, ' ');
          const barColor = value >= 9 ? 'var(--color-success)' :
                           value >= 7 ? 'var(--color-accent)' :
                           value >= 5 ? 'var(--color-warning)' :
                           'var(--color-error, #e84040)';
          const anchor = scoreAnchors[key];
          const Tag = anchor ? 'a' : 'div';
          return (
            <Tag class="breakdown-item" {...(anchor ? { href: anchor } : {})}>
              <div class="breakdown-header">
                <span class="breakdown-label">{label}</span>
                <span class="breakdown-value" style={`color: ${barColor}`}>{value}/10</span>
              </div>
              <div class="breakdown-bar">
                <div class="breakdown-fill" style={`width: ${value * 10}%; background: ${barColor}`}></div>
              </div>
            </Tag>
          );
        })}
      </div>
    </section>

    <nav class="pipeline-nav" aria-label="Compiler pipeline phases">
      <h2>Pipeline Phases</h2>
      <div class="pipeline-steps">
        {pipelinePhases.map(phase => (
          <a href={phase.anchor} class="phase-link">
            <span class="phase-icon">{phase.icon}</span>
            <span class="phase-name">{phase.name}</span>
          </a>
        ))}
      </div>
    </nav>

    <div class="feature-tags">
      {d.features.map(f => (
        <span class="feature-tag">{f.replace(/_/g, ' ')}</span>
      ))}
    </div>

    <article class="journey-content">
      <Content />
    </article>
  </main>
</BaseLayout>

<script>
  document.querySelectorAll('.journey-content details').forEach(d => d.setAttribute('open', ''));
</script>

<style>
  .journey-page {
    max-width: var(--max-width-narrow, 800px);
    margin: 0 auto;
    padding: var(--space-6) var(--space-8);
  }

  /* Hero */
  .journey-hero {
    padding: var(--space-8) 0 var(--space-6);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .hero-top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .journey-number {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
  }

  .difficulty-badge {
    font-size: 0.625rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: var(--radius-full, 9999px);
    background: color-mix(in srgb, var(--badge-color) 15%, transparent);
    color: var(--badge-color);
  }

  .journey-hero h1 {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
    line-height: 1.15;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
    line-height: var(--leading-relaxed, 1.65);
  }

  .hero-date {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  /* Hero meta strip */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding: var(--space-4);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .meta-label {
    font-size: 0.625rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-value {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }

  .meta-value.bugs {
    color: var(--color-warning);
  }

  .status-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full, 9999px);
    letter-spacing: 0.05em;
  }

  .status-badge.pass {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .status-badge.fail {
    background: rgba(232, 64, 64, 0.15);
    color: var(--color-error, #e84040);
  }

  .overflow-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full, 9999px);
    letter-spacing: 0.05em;
  }

  .overflow-badge.pass {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .overflow-badge.fail {
    background: rgba(232, 64, 64, 0.15);
    color: var(--color-error, #e84040);
  }

  /* Score ring (large) */
  .score-ring-lg {
    position: relative;
    width: 48px;
    height: 48px;
  }

  .score-ring-lg svg {
    width: 48px;
    height: 48px;
    transform: rotate(-90deg);
  }

  .score-bg {
    fill: none;
    stroke: var(--color-bg-tertiary);
    stroke-width: 3;
  }

  .score-fill {
    fill: none;
    stroke-width: 3;
    stroke-linecap: round;
  }

  .score-value-lg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }

  /* Learning objectives */
  .learning-objectives {
    margin-bottom: var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: rgba(116, 179, 176, 0.05);
    border: 1px solid rgba(116, 179, 176, 0.15);
    border-radius: var(--radius-lg);
  }

  .learning-objectives h2 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    margin: 0 0 var(--space-3) 0;
  }

  .learning-objectives ul {
    margin: 0;
    padding-left: var(--space-5);
    list-style-type: disc;
  }

  .learning-objectives li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }

  /* Score breakdown */
  .score-breakdown-section {
    margin-bottom: var(--space-6);
  }

  .score-breakdown-section h2 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
  }

  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-3);
  }

  .breakdown-item {
    display: block;
    padding: var(--space-3);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
  }

  a.breakdown-item {
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  a.breakdown-item:hover {
    border-color: var(--color-accent);
    background: rgba(116, 179, 176, 0.08);
  }

  .breakdown-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-2);
  }

  .breakdown-label {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-transform: capitalize;
  }

  .breakdown-value {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
  }

  .breakdown-bar {
    height: 4px;
    background: var(--color-bg-tertiary);
    border-radius: 9999px;
    overflow: hidden;
  }

  .breakdown-fill {
    height: 100%;
    border-radius: 9999px;
    transition: width 0.4s ease;
  }

  /* Pipeline navigation */
  .pipeline-nav {
    margin-bottom: var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .pipeline-nav h2 {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-3) 0;
  }

  .pipeline-steps {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .phase-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
    font-size: var(--text-xs);
  }

  .phase-link:hover {
    border-color: var(--color-accent);
    background: rgba(116, 179, 176, 0.08);
  }

  .phase-icon {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    background: rgba(116, 179, 176, 0.15);
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
  }

  .phase-name {
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }

  /* Feature tags */
  .feature-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .feature-tag {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full, 9999px);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  /* Journey article content */
  .journey-content {
    line-height: var(--leading-relaxed, 1.65);
  }

  .journey-content :global(h1),
  .journey-content :global(h2),
  .journey-content :global(h3),
  .journey-content :global(h4) {
    scroll-margin-top: calc(var(--header-height) + var(--space-4));
  }

  .journey-content :global(h1) {
    font-size: var(--text-2xl);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-accent);
  }

  .journey-content :global(h2) {
    font-size: var(--text-xl);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .journey-content :global(h3) {
    font-size: var(--text-lg);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .journey-content :global(h4) {
    font-size: var(--text-base);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    color: var(--color-text-secondary);
  }

  .journey-content :global(p) {
    margin-bottom: var(--space-4);
  }

  .journey-content :global(ul) {
    margin-bottom: var(--space-4);
    list-style-type: disc !important;
    list-style-position: outside;
    padding-left: var(--space-6);
  }

  .journey-content :global(ol) {
    margin-bottom: var(--space-4);
    list-style-type: decimal !important;
    list-style-position: outside;
    padding-left: var(--space-6);
  }

  .journey-content :global(li) {
    display: list-item;
    margin-bottom: var(--space-1);
  }

  .journey-content :global(pre) {
    margin-bottom: var(--space-4);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }

  .journey-content :global(table) {
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
    width: 100%;
    border-collapse: collapse;
  }

  .journey-content :global(th),
  .journey-content :global(td) {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .journey-content :global(th) {
    background: var(--color-bg-tertiary);
    font-weight: var(--weight-semibold);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .journey-content :global(blockquote) {
    margin-bottom: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-left: 3px solid var(--color-accent);
    background: rgba(116, 179, 176, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .journey-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-bg-code, rgba(22, 22, 22, 0.3));
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }

  .journey-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .journey-content :global(strong) {
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
  }

  .journey-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .journey-content :global(a:hover) {
    text-decoration: underline;
  }

  .journey-content :global(details) {
    margin-bottom: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .journey-content :global(details summary) {
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: default;
    list-style: none;
    pointer-events: none;
  }

  .journey-content :global(details summary::marker),
  .journey-content :global(details summary::-webkit-details-marker) {
    display: none;
  }

  .journey-content :global(details > :not(summary)) {
    padding: 0 var(--space-4);
  }

  .journey-content :global(details > p:first-of-type) {
    padding-top: var(--space-3);
  }

  .journey-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  @media (max-width: 768px) {
    .journey-page {
      padding: var(--space-4);
    }

    .journey-hero h1 {
      font-size: var(--text-3xl);
    }

    .hero-meta {
      gap: var(--space-4);
    }

    .breakdown-grid {
      grid-template-columns: 1fr;
    }

    .pipeline-steps {
      gap: var(--space-1);
    }

    .phase-link {
