---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  backLink: { url: string; label: string };
  statusBadge?: { text: string; color: string };
  progress?: { done: number; total: number };
}

const { title, description, backLink, statusBadge, progress } = Astro.props;
const currentPath = Astro.url.pathname;

const seoDescription = description ||
  `${title} — Ori programming language development details.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: backLink.label, url: backLink.url },
  { name: title, url: currentPath },
];
---

<BaseLayout
  title={`${title} — Ori`}
  description={seoDescription}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  <div class="detail-layout">
    <div class="detail-content">
      <nav class="detail-nav">
        <a href={backLink.url} class="back-link">
          <span class="back-arrow" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="12" height="12" fill="currentColor" style="vertical-align: -0.125em"><path d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 288 480 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-370.7 0 105.4-105.4c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/></svg></span>
          {backLink.label}
        </a>
        {statusBadge && (
          <span class={`status-badge status-${statusBadge.color}`}>
            {statusBadge.text}
          </span>
        )}
      </nav>
      {progress && (
        <div class="detail-progress">
          <div class="detail-progress-bar">
            <div class="detail-progress-fill" style={`width: ${(progress.done / progress.total) * 100}%`}></div>
          </div>
          <span class="detail-progress-text">{Math.round((progress.done / progress.total) * 100)}%</span>
        </div>
      )}
      <article class="detail-article">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .detail-layout {
    min-height: calc(100vh - var(--header-height, 56px));
  }

  .detail-content {
    max-width: var(--max-width-narrow, 800px);
    margin: 0 auto;
    padding: var(--space-6, 1.5rem) var(--space-8, 2rem);
  }

  .detail-nav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .back-arrow {
    display: inline-flex;
    align-items: center;
  }

  .status-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    margin-left: auto;
  }

  .status-badge.status-success {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .status-badge.status-warning {
    background: rgba(219, 132, 75, 0.15);
    color: var(--color-warning);
  }

  .status-badge.status-error {
    background: rgba(232, 64, 64, 0.15);
    color: var(--color-error, #e84040);
  }

  .status-badge.status-muted {
    background: var(--color-bg-tertiary);
    color: var(--color-text-muted);
  }

  /* Progress bar */
  .detail-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .detail-progress-bar {
    flex: 1;
    height: 8px;
    background: var(--color-bg-tertiary);
    border-radius: 9999px;
    overflow: hidden;
  }

  .detail-progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 9999px;
    transition: width var(--transition-base);
  }

  .detail-progress-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Article typography — matches DocsLayout */
  .detail-article {
    line-height: var(--leading-relaxed, 1.65);
  }

  .detail-article :global(h1) {
    margin-bottom: var(--space-6, 1.5rem);
  }

  .detail-article :global(h2) {
    margin-top: var(--space-10, 2.5rem);
    margin-bottom: var(--space-4, 1rem);
    padding-bottom: var(--space-2, 0.5rem);
    border-bottom: 1px solid var(--color-border, #30333a);
  }

  .detail-article :global(h3) {
    margin-top: var(--space-8, 2rem);
    margin-bottom: var(--space-3, 0.75rem);
  }

  .detail-article :global(p) {
    margin-bottom: var(--space-4, 1rem);
  }

  .detail-article :global(ul) {
    margin-bottom: var(--space-4, 1rem);
    list-style-type: disc !important;
    list-style-position: outside;
    padding-left: var(--space-6, 1.5rem);
  }

  .detail-article :global(ol) {
    margin-bottom: var(--space-4, 1rem);
    list-style-type: decimal !important;
    list-style-position: outside;
    padding-left: var(--space-6, 1.5rem);
  }

  .detail-article :global(li) {
    display: list-item;
  }

  /* Task list checkboxes — no bullet points */
  .detail-article :global(ul.contains-task-list) {
    list-style-type: none !important;
    padding-left: var(--space-4, 1rem);
  }

  .detail-article :global(li.task-list-item) {
    list-style-type: none;
    padding-left: 24px;
    text-indent: -24px;
  }

  .detail-article :global(li:has(> input[type="checkbox"])) {
    list-style-type: none;
    padding-left: 24px;
    text-indent: -24px;
  }

  .detail-article :global(input[type="checkbox"]) {
    margin-right: var(--space-2, 0.5rem);
    pointer-events: none;
    appearance: none;
    -webkit-appearance: none;
    width: 15px;
    height: 15px;
    border: 1px solid rgba(164, 161, 157, 0.4);
    border-radius: 3px;
    background: transparent;
    vertical-align: middle;
    position: relative;
  }

  .detail-article :global(input[type="checkbox"][checked]) {
    background: rgba(116, 179, 176, 0.2);
    border-color: rgba(116, 179, 176, 0.4);
  }

  .detail-article :global(input[type="checkbox"][checked])::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 1px;
    width: 5px;
    height: 9px;
    border: solid #74b3b0;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  /* Standalone checkbox paragraphs */
  .detail-article :global(p:has(> input[type="checkbox"])) {
    padding-left: var(--space-4, 1rem);
  }

  .detail-article :global(pre) {
    margin-bottom: var(--space-4, 1rem);
  }

  .detail-article :global(table) {
    margin-bottom: var(--space-4, 1rem);
    font-size: var(--text-sm, 0.875rem);
  }

  .detail-article :global(blockquote) {
    margin-bottom: var(--space-4, 1rem);
    padding-left: var(--space-4, 1rem);
    border-left: 3px solid var(--color-border, #30333a);
    color: var(--color-text-secondary);
  }

  .detail-article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-bg-code, rgba(20, 22, 26, 0.3));
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }

  .detail-article :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .detail-article :global(strong) {
    font-weight: var(--weight-semibold, 600);
    color: var(--color-text-primary);
  }

  .detail-article :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .detail-article :global(a:hover) {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .detail-content {
      padding: var(--space-4, 1rem);
    }
  }
</style>
