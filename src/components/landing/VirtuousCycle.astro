---
const root = { label: 'Value Semantics', detail: 'Every variable owns its data. No shared mutation. No aliasing.' };

const branches = [
  { label: 'Safe Memory', detail: 'No aliasing lets ARC optimize: in-place reuse, borrow inference, copy-on-write — all automatic.' },
  { label: 'Complete Effects', detail: 'No hidden mutation means capabilities see every side effect. Nothing escapes.' },
  { label: 'Trivial Mocking', detail: 'Capabilities are injectable. Replace any effect with `with...in`. No frameworks needed.' },
  { label: 'Safe Refactoring', detail: 'Smart testing + dependency tracking = change with confidence. Tests that know your code.' },
];
---

<section class="cycle">
  <div class="cycle-inner">
    <span class="section-tag">Architecture</span>
    <h2 class="cycle-heading">The Design That Compounds</h2>
    <p class="cycle-subtitle">
      Not independent features bolted together — one design choice with compounding returns.
    </p>

    <div class="compound-layout">
      <div class="root-card glass">
        <h3 class="root-label">{root.label}</h3>
        <p class="root-detail">{root.detail}</p>
      </div>

      <div class="branch-connector" aria-hidden="true">
        <div class="connector-stem"></div>
        <div class="connector-bar">
          {branches.map(() => <div class="connector-drop"></div>)}
        </div>
      </div>

      <div class="branch-grid">
        {branches.map((branch) => (
          <div class="branch-card glass-subtle">
            <h3 class="card-label">{branch.label}</h3>
            <p class="card-detail">{branch.detail}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .cycle {
    padding: var(--space-16) 0;
    background: var(--color-bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }

  .cycle-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-tag {
    display: block;
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--sage-400);
    margin-bottom: var(--space-3);
  }

  .cycle-heading {
    text-align: center;
    margin-bottom: var(--space-3);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  .cycle-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-10);
    font-size: var(--text-lg);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .compound-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .root-card {
    text-align: center;
    padding: var(--space-5) var(--space-8);
    max-width: 420px;
    width: 100%;
  }

  .root-label {
    font-weight: var(--weight-bold);
    font-size: var(--text-xl);
    color: var(--sage-300);
    margin: 0 0 var(--space-1) 0;
  }

  .root-detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .branch-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .connector-stem {
    width: 2px;
    height: var(--space-6);
    background: var(--glass-border-hover);
  }

  .connector-bar {
    display: flex;
    justify-content: space-around;
    width: 100%;
    position: relative;
  }

  .connector-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 12.5%;
    right: 12.5%;
    height: 2px;
    background: var(--glass-border-hover);
  }

  .connector-drop {
    width: 2px;
    height: var(--space-4);
    background: var(--glass-border-hover);
  }

  .branch-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    width: 100%;
  }

  .branch-card {
    padding: var(--space-4);
    transition: border-color var(--transition-medium), transform var(--transition-medium);
  }

  .branch-card:hover {
    border-color: var(--glass-border-hover);
    transform: translateY(-2px);
  }

  .card-label {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--copper-300);
    margin: 0 0 var(--space-2) 0;
  }

  .card-detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 900px) {
    .branch-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .branch-connector {
      display: none;
    }

    .compound-layout {
      gap: var(--space-6);
    }
  }

  @media (max-width: 600px) {
    .branch-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
