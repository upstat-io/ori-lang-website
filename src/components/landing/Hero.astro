---
import fs from 'node:fs';
import path from 'node:path';
import { Code } from 'astro:components';

const version = fs.readFileSync(path.resolve('..', 'ori_lang', 'BUILD_NUMBER'), 'utf-8').trim();
const oriDarkTheme = JSON.parse(fs.readFileSync(path.resolve('src', 'shiki', 'ori-dark-theme.json'), 'utf-8'));
const oriGrammar = JSON.parse(fs.readFileSync(path.resolve('src', 'shiki', 'ori.tmLanguage.json'), 'utf-8'));
const oriLang = { id: 'ori', scopeName: 'source.ori', grammar: oriGrammar, aliases: ['ori'] };

const sampleCode = `// real http — declared, not hidden
@fetch_user (id: int) -> Result<User, Error>
    uses Http = {
    let resp = Http.get(url: \`/users/{id}\`)?;
    resp.json() as? User
}

// test it — swap the capability, no frameworks
@test_fetch_user tests @fetch_user () -> void = {
    let mock_api = handler(state: ()) {
        get: (s, url:) -> (s, Response.json(
            body: { "name": "Ori", "id": 1 }
        ))
    };

    with Http = mock_api in {
        let user = fetch_user(id: 1).unwrap();
        assert_eq(actual: user.name, expected: "Ori");
    }
}`;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-header">
        <h1 class="hero-title">Ori</h1>
        <a href="/changelog" class="hero-version">v{version}</a>
      </div>
      <p class="hero-desc">
        A statically-typed compiled language with value semantics, Hindley-Milner type inference, ARC memory management, and an explicit capability effect system. Compiles to native binaries via LLVM.
      </p>
      <div class="hero-actions">
        <a href="/guide/01-getting-started" class="btn primary">Get Started</a>
        <a href="/playground" class="btn">Playground</a>
      </div>
      <pre class="hero-install"><code>curl -fsSL https://ori-lang.com/install.sh | sh</code></pre>
    </div>
    <div class="hero-right">
      <div class="code-frame">
        <div class="code-frame-header">
          <span class="code-frame-label">user.ori</span>
        </div>
        <div class="code-frame-body">
          <Code code={sampleCode} lang={oriLang} theme={oriDarkTheme} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-semibold);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .hero-version {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .hero-version:hover {
    color: var(--sage-300);
  }

  .hero-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--glass-border);
    text-decoration: none;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .btn:hover {
    color: var(--color-text-primary);
    border-color: var(--glass-border-hover);
  }

  .btn.primary {
    color: var(--sage-300);
    border-color: var(--sage-700);
  }

  .btn.primary:hover {
    color: var(--sage-200);
    border-color: var(--sage-500);
  }

  .hero-install {
    display: inline-block;
    background: var(--color-bg-code);
    border: 1px solid var(--glass-border);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero-install code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  /* Code frame */
  .code-frame {
    border: 1px solid rgba(255, 255, 255, 0.20);
    background: #111215;
  }

  .code-frame-header {
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background: #1c1e22;
  }

  .code-frame-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .code-frame-body :global(pre) {
    padding: var(--space-4) !important;
    margin: 0 !important;
    background: transparent !important;
    border: none !important;
    font-size: var(--text-sm) !important;
    line-height: 1.6 !important;
    overflow-x: auto;
  }

  .code-frame-body :global(pre code) {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-size: inherit !important;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-title {
      font-size: var(--text-3xl);
    }

    .hero-links {
      flex-wrap: wrap;
      gap: var(--space-4);
    }
  }
</style>
