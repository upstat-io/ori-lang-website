---
import fs from 'node:fs';
import path from 'node:path';
import { Code } from 'astro:components';

const version = fs.readFileSync(path.resolve('..', 'ori_lang', 'BUILD_NUMBER'), 'utf-8').trim();
const oriDarkTheme = JSON.parse(fs.readFileSync(path.resolve('src', 'shiki', 'ori-dark-theme.json'), 'utf-8'));
const oriGrammar = JSON.parse(fs.readFileSync(path.resolve('src', 'shiki', 'ori.tmLanguage.json'), 'utf-8'));
const oriLang = { id: 'ori', scopeName: 'source.ori', grammar: oriGrammar, aliases: ['ori'] };

const sampleCode = `// real http — declared, not hidden
@fetch_user (id: int) -> Result<User, Error>
    uses Http = {
    let resp = Http.get(url: \`/users/{id}\`)?;
    resp.json() as? User
}

// test it — swap the capability, no frameworks
@test_fetch_user tests @fetch_user () -> void = {
    let mock_api = handler(state: ()) {
        get: (s, url:) -> (s, Response.json(
            body: { "name": "Ori", "id": 1 }
        ))
    };

    with Http = mock_api in {
        let user = fetch_user(id: 1).unwrap();
        assert_eq(actual: user.name, expected: "Ori");
    }
}`;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-header">
        <h1 class="hero-title">OriLang</h1>
        <a href="/changelog" class="hero-version">v{version}</a>
      </div>
      <p class="hero-subtitle">A compiled programming language designed for safety, speed, and testability.</p>
      <ul class="hero-traits">
        <li>Compiles to native binaries — no runtime, no VM</li>
        <li>No garbage collector. No borrow checker.</li>
        <li>Side effects declared in function signatures</li>
        <li>Mocking built into the language</li>
      </ul>
      <div class="hero-actions">
        <a href="/guide/01-getting-started" class="btn primary">Get Started</a>
        <a href="/playground" class="btn">Playground</a>
      </div>
      <div class="hero-install-wrap">
        <pre class="hero-install"><code><span class="prompt">$</span> curl -fsSL https://ori-lang.com/install.sh | sh</code></pre>
        <button class="copy-btn" data-copy="curl -fsSL https://ori-lang.com/install.sh | sh" aria-label="Copy install command">
          <svg class="icon-copy" width="14" height="14" viewBox="0 0 448 512" fill="currentColor"><path d="M384 336l-192 0c-8.8 0-16-7.2-16-16l0-256c0-8.8 7.2-16 16-16l140.1 0L400 115.9 400 320c0 8.8-7.2 16-16 16zM192 384l192 0c35.3 0 64-28.7 64-64l0-204.1c0-12.7-5.1-24.9-14.1-33.9L366.1 14.1c-9-9-21.2-14.1-33.9-14.1L192 0c-35.3 0-64 28.7-64 64l0 256c0 35.3 28.7 64 64 64zM64 128c-35.3 0-64 28.7-64 64L0 448c0 35.3 28.7 64 64 64l192 0c35.3 0 64-28.7 64-64l0-32-48 0 0 32c0 8.8-7.2 16-16 16L64 464c-8.8 0-16-7.2-16-16l0-256c0-8.8 7.2-16 16-16l32 0 0-48-32 0z"/></svg>
          <svg class="icon-check" width="14" height="14" viewBox="0 0 448 512" fill="currentColor"><path d="M441 103c9.4 9.4 9.4 24.6 0 33.9L177 401c-9.4 9.4-24.6 9.4-33.9 0L7 265c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0l119 119L407 103c9.4-9.4 24.6-9.4 33.9 0z"/></svg>
        </button>
      </div>
    </div>
    <div class="hero-right">
      <div class="code-frame">
        <div class="code-frame-header">
          <span class="code-frame-label">user.ori</span>
        </div>
        <div class="code-frame-body">
          <Code code={sampleCode} lang={oriLang} theme={oriDarkTheme} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .hero-version {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .hero-version:hover {
    color: var(--sage-300);
  }

  .hero-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6) 0;
    line-height: 1.5;
  }

  .hero-traits {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8) 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 2px solid var(--sage-500);
  }

  .hero-traits li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    padding: var(--space-2) 0 var(--space-2) var(--space-4);
    margin: 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .hero-traits li:last-child {
    border-bottom: none;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--glass-border);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .btn:hover {
    color: var(--sage-300);
    border-color: var(--sage-300);
  }

  .btn.primary {
    color: var(--sage-300);
    border-color: var(--sage-500);
  }

  .btn.primary:hover {
    color: var(--sage-200);
    border-color: var(--sage-400);
  }

  .hero-install {
    display: inline-block;
    background: var(--color-bg-code);
    border: 1px solid var(--glass-border);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .prompt {
    color: var(--copper-400);
    margin-right: var(--space-2);
  }

  .hero-install code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .hero-install-wrap {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
  }

  .hero-install-wrap .hero-install {
    border-right: none;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    background: var(--color-bg-code);
    border: 1px solid var(--glass-border);
    padding: var(--space-2);
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .copy-btn:hover {
    color: var(--sage-300);
    border-color: var(--sage-300);
  }

  .copy-btn .icon-check {
    display: none;
  }

  .copy-btn.copied .icon-copy {
    display: none;
  }

  .copy-btn.copied .icon-check {
    display: block;
    color: var(--sage-300);
  }

  /* Code frame */
  .code-frame {
    border: 1px solid rgba(255, 255, 255, 0.20);
    background: #0e1114;
  }

  .code-frame-header {
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background: #1c1e22;
  }

  .code-frame-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--copper-400);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .code-frame-body :global(pre) {
    padding: var(--space-4) !important;
    margin: 0 !important;
    background: transparent !important;
    border: none !important;
    font-size: var(--text-sm) !important;
    line-height: 1.6 !important;
    overflow-x: auto;
  }

  .code-frame-body :global(pre code) {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-size: inherit !important;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-title {
      font-size: var(--text-3xl);
    }

    .hero-links {
      flex-wrap: wrap;
      gap: var(--space-4);
    }
  }
</style>

<script>
  document.querySelector('.copy-btn')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const text = btn.dataset.copy ?? '';
    navigator.clipboard.writeText(text).then(() => {
      btn.classList.add('copied');
      setTimeout(() => { btn.classList.remove('copied'); }, 2000);
    });
  });
</script>
