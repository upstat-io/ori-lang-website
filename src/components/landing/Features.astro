---
const features = [
  {
    title: 'Compiles to Native Executables',
    description: 'Write your code, compile it, ship a single binary. Ori produces standalone executables for Windows, Linux, and macOS — your users don\'t need Ori installed. No runtime, no VM, no interpreter required.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="m9 9 6 6"/><path d="m15 9-6 6"/></svg>`,
  },
  {
    title: 'The Memory Model Nobody Else Has',
    description: 'No garbage collector. No borrow checker. No manual allocation. Eight stacked optimizations turn functional code into in-place mutations — zero compromise between safety and speed.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  },
  {
    title: 'Effects You Can See',
    description: 'Side effects are explicit. Every function declares its capabilities. Mocking is built-in — just provide a different implementation with `with...in`. No frameworks. No DI containers.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    title: 'Smart Testing',
    description: 'Tests live in the dependency graph. Change a function, and every affected test runs automatically. Your tests even make your binary faster — they\'re automatic profiling data for the optimizer.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
  },
];
---

<section class="features">
  <div class="features-inner">
    <span class="section-tag">Core principles</span>
    <h2 class="features-heading">A compiled language where functional code runs at native speed</h2>
    <div class="features-grid">
      {features.map(feature => (
        <div class="feature-card">
          <div class="feature-header">
            <div class="feature-icon" set:html={feature.icon} />
            <h3 class="feature-title">{feature.title}</h3>
          </div>
          <p class="feature-desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--glass-border);
  }

  .features-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-tag {
    display: block;
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--copper-400);
    margin-bottom: var(--space-3);
  }

  .features-heading {
    text-align: center;
    margin-bottom: var(--space-12);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    letter-spacing: -0.01em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .feature-card {
    padding: var(--space-6);
    border: 1px solid var(--glass-border);
    background: var(--color-bg-secondary);
  }

  .feature-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .feature-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--copper-400);
  }

  .feature-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .feature-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--copper-400);
  }

  .feature-desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
