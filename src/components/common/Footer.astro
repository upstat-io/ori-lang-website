---
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <svg class="footer-logo" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="footer-logo-bg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#3a3412"/>
            <stop offset="100%" stop-color="#132a2f"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" fill="url(#footer-logo-bg)"/>
        <path d="M9 9 L17 16 L9 23" stroke="#beac3c" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M17 9 L25 16 L17 23" stroke="#74b3b0" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="footer-brand">OriLang</span>
      <span class="footer-sep">&middot;</span>
      <span>A project by <a href="https://upstat.io" target="_blank" rel="noopener" class="upstat-link">upstat.io</a></span>
    </div>
    <div class="footer-right">
      <a href="https://github.com/upstat-io/ori-lang" target="_blank" rel="noopener">GitHub</a>
      <span class="footer-sep">&middot;</span>
      <a href="https://github.com/sponsors/upstat-io" target="_blank" rel="noopener">Sponsor</a>
      <span class="footer-sep">&middot;</span>
      <a href="/guide/01-getting-started">Docs</a>
      <span class="footer-sep">&middot;</span>
      <a href="/roadmap">Roadmap</a>
      <span class="footer-sep">&middot;</span>
      <a href="/playground">Playground</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    padding: var(--space-4) 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-logo {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .footer-brand {
    font-family: var(--font-mono);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-sep {
    color: var(--color-border);
  }

  .footer-right a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-right a:hover {
    color: var(--sage-300);
  }

  .upstat-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .upstat-link:hover {
    color: var(--sage-300);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-2);
      text-align: center;
    }
  }
</style>
