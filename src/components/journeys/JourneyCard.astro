---
interface Props {
  journey: number;
  slug: string;
  theme: string;
  difficulty: 'simple' | 'moderate' | 'complex';
  score: number;
  status: string;
  features: string[];
  featureDescription: string;
  bugsFound: number;
}

const { journey, slug, theme, difficulty, score, status, features, featureDescription, bugsFound } = Astro.props;

const scoreColor = score >= 9 ? 'var(--color-success)' :
                   score >= 7 ? 'var(--color-accent)' :
                   score >= 5 ? 'var(--color-warning)' :
                   'var(--color-error)';

const difficultyLabel = { simple: 'Simple', moderate: 'Moderate', complex: 'Complex' }[difficulty];
const difficultyColor = { simple: 'var(--color-text-muted)', moderate: 'var(--color-accent)', complex: 'var(--color-primary)' }[difficulty];

const statusPassed = status === 'PASS';
---

<a href={`/journeys/${slug}/`} class="journey-card">
  <div class="card-header">
    <span class="journey-number">#{String(journey).padStart(2, '0')}</span>
    <span class="difficulty-badge" style={`--badge-color: ${difficultyColor}`}>{difficultyLabel}</span>
  </div>

  <h3 class="journey-theme">{theme}</h3>
  <p class="journey-description">{featureDescription}</p>

  <div class="card-features">
    {features.slice(0, 4).map(f => (
      <span class="feature-tag">{f.replace(/_/g, ' ')}</span>
    ))}
    {features.length > 4 && (
      <span class="feature-tag feature-more">+{features.length - 4}</span>
    )}
  </div>

  <div class="card-footer">
    <div class="score-display">
      <svg class="score-ring" viewBox="0 0 36 36">
        <path class="score-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
        <path class="score-fill" style={`stroke: ${scoreColor}; stroke-dasharray: ${score * 10}, 100`}
          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
      </svg>
      <span class="score-value" style={`color: ${scoreColor}`}>{score}</span>
    </div>
    <div class="card-meta">
      <span class={`status-indicator ${statusPassed ? 'pass' : 'fail'}`}>
        {statusPassed ? 'PASS' : 'FAIL'}
      </span>
      {bugsFound > 0 && (
        <span class="bugs-count">{bugsFound} bugs found</span>
      )}
    </div>
  </div>
</a>

<style>
  .journey-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    padding: var(--space-5);
    text-decoration: none;
    transition: border-color var(--transition-fast);
  }

  .journey-card:hover {
    border-color: var(--color-border-hover);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .journey-number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--copper-400);
  }

  .difficulty-badge {
    font-size: 0.625rem;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    background: color-mix(in srgb, var(--badge-color) 15%, transparent);
    color: var(--badge-color);
  }

  .journey-theme {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2) 0;
    line-height: 1.3;
  }

  .journey-description {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.4;
    flex: 1;
  }

  .card-features {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: var(--space-4);
  }

  .feature-tag {
    font-size: 0.625rem;
    padding: 1px 5px;
    border: 1px solid var(--glass-border);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .feature-more {
    color: var(--color-accent);
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .score-display {
    position: relative;
    width: 40px;
    height: 40px;
  }

  .score-ring {
    width: 40px;
    height: 40px;
    transform: rotate(-90deg);
  }

  .score-bg {
    fill: none;
    stroke: var(--color-bg-tertiary);
    stroke-width: 3;
  }

  .score-fill {
    fill: none;
    stroke-width: 3;
    stroke-linecap: round;
    transition: stroke-dasharray 0.6s ease;
  }

  .score-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .status-indicator {
    font-size: 0.625rem;
    font-weight: var(--weight-bold);
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: var(--radius-full, 9999px);
  }

  .status-indicator.pass {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .status-indicator.fail {
    background: rgba(232, 64, 64, 0.15);
    color: var(--color-error);
  }

  .bugs-count {
    font-size: 0.625rem;
    color: var(--color-warning);
  }
</style>
