---
interface Props {
  href: string;
  num: number | string;
  name: string;
  status: 'complete' | 'partial' | 'not-started';
  note?: string;
  goal: string;
  done: number;
  total: number;
  id?: string;
}

const { href, num, name, status, note, goal, done, total, id } = Astro.props;

const statusLabel = status === 'complete' ? 'Complete' :
                    status === 'partial' ? 'In Progress' : 'Not Started';

const statusClass = status === 'complete' ? 'success' :
                    status === 'partial' ? 'warning' : 'muted';

const pct = total > 0 ? (done / total) * 100 : 0;
const fillWidth = status === 'complete' ? 100 : pct;
---

<a
  id={id}
  class={`section-card ${status}`}
  href={href}
>
  <div class="section-header">
    <span class="section-num">Section {num}</span>
    <span class={`section-status ${statusClass}`}>{statusLabel}</span>
  </div>
  <h3>{name}</h3>
  <p class="section-note">{note || goal}</p>
  <div class="section-progress">
    <div class="progress-bar">
      <div class="progress-fill" style={`width: ${fillWidth}%`}></div>
    </div>
    <span class="progress-text">{done}/{total} tasks</span>
  </div>
</a>

<style>
  .section-card {
    display: flex;
    flex-direction: column;
    height: 140px;
    background: var(--glass-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    cursor: pointer;
    transition: all var(--transition-medium);
    text-align: left;
    text-decoration: none;
    color: inherit;
  }

  .section-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .section-card:hover {
    border-color: var(--color-border-hover, var(--color-border));
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .section-card.complete {
    border-left: 3px solid var(--color-success);
  }

  .section-card.partial {
    border-left: 3px solid var(--color-warning);
  }

  .section-card.not-started {
    border-left: 3px solid var(--color-text-muted);
    opacity: 0.8;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
    flex-shrink: 0;
  }

  .section-num {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
  }

  .section-status {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    padding: 2px 6px;
    border-radius: var(--radius-full);
  }

  .section-status.success {
    background: rgba(116, 179, 176, 0.15);
    color: var(--color-success);
  }

  .section-status.warning {
    background: rgba(219, 132, 75, 0.15);
    color: var(--color-warning);
  }

  .section-status.muted {
    background: var(--color-bg-tertiary);
    color: var(--color-text-muted);
  }

  .section-card h3 {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2) 0;
    flex-shrink: 0;
  }

  .section-progress {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    margin-top: auto;
  }

  .progress-bar {
    flex: 1;
    height: 4px;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    transition: width var(--transition-base);
  }

  .section-card.complete .progress-fill {
    background: var(--color-success);
  }

  .section-card.partial .progress-fill {
    background: var(--color-warning);
  }

  .progress-text {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .section-note {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin: 0;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-clamp: 2;
    min-height: 0;
  }

  /* Highlight animation classes (set via JS on roadmap index) */
  .section-card:global(.highlight.complete) {
    animation: highlight-flash-success 1.5s ease-out;
  }

  .section-card:global(.highlight.partial) {
    animation: highlight-flash-warning 1.5s ease-out;
  }

  .section-card:global(.highlight.not-started) {
    animation: highlight-flash-muted 1.5s ease-out;
  }

  @keyframes highlight-flash-success {
    0%, 30% { background: rgba(116, 179, 176, 0.2); }
    100% { background: var(--glass-bg-alt); }
  }

  @keyframes highlight-flash-warning {
    0%, 30% { background: rgba(219, 132, 75, 0.2); }
    100% { background: var(--glass-bg-alt); }
  }

  @keyframes highlight-flash-muted {
    0%, 30% { background: rgba(164, 161, 157, 0.15); }
    100% { background: var(--glass-bg-alt); }
  }
</style>
